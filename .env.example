# ============================================================================
# CRR RV Park Platform — Environment Variables (TEMPLATE)
# ============================================================================
# Copy this file to `.env` and fill in the real values. NEVER put real secrets
# in this template — it gets shipped into build environments and may be read
# by tooling or successors. Treat `.env` itself as a password vault: local
# only, never committed, never shared over email/Slack/anywhere.
#
# For production: set the real values in the Netlify dashboard under:
#   Site settings → Environment variables
# ============================================================================

# ---- Supabase (Postgres + Auth + Storage) ----
# Get these from the Supabase dashboard: Project Settings → API
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME               # Public anon key, but still treat as sensitive
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME                   # SECRET — server-only, bypasses RLS

# ---- Netlify rebuild hook ----
# Calendar sync triggers this after event data changes so the prerendered
# events page refreshes. Create it under Site configuration → Build hooks.
NETLIFY_BUILD_HOOK=                               # SECRET build-hook URL

# ---- Zoho OAuth (Drive + Calendar) ----
# Create an OAuth app at: api-console.zoho.com → Self Client (or Server-based)
ZOHO_CLIENT_ID=1000.REPLACE_ME
ZOHO_CLIENT_SECRET=REPLACE_ME                     # SECRET
ZOHO_REDIRECT_URI=https://www.crookedriverranchrv.com/api/zoho/oauth-callback
ZOHO_REFRESH_TOKEN=                               # Obtained via OAuth flow, stored in DB after first auth
ZOHO_ACCOUNT_DOMAIN=com                           # 'com' for US, 'eu' for Europe, etc.

# ---- Zoho resource IDs (set after designating the team folder + calendar) ----
ZOHO_WORKDRIVE_MEDIA_FOLDER_ID=                   # Team Folder ID for website media
ZOHO_CALENDAR_PUBLIC_EVENTS_ID=                   # Calendar UID for public events

# ---- Scheduled functions ----
SCHEDULED_FN_SECRET=REPLACE_ME                    # SECRET — shared secret sent as x-cron-secret header by cron

# ---- Google Maps / Places ----
# Browser key: HTTP-referrer restricted to the production domains + approved dev hosts.
PUBLIC_GOOGLE_MAPS_API_KEY=REPLACE_ME
PUBLIC_GOOGLE_SITE_VERIFICATION=                 # Optional Search Console HTML verification token
# Optional Google Cloud map ID. Without it, maps use compatible classic markers.
PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server keys: never expose in the browser. Restrict each to the APIs it needs.
GOOGLE_PLACES_API_KEY=REPLACE_ME                  # Place photos, geocoding, static maps
GOOGLE_MAPS_SERVER_KEY=REPLACE_ME                 # Places API (New) lookup/admin enrichment
# Optional operational override for the park's stored public Google Place ID.
GOOGLE_RV_PARK_PLACE_ID=

# ---- Misc ----
SITE_URL=https://crookedriverranchrv.com
ADMIN_EMAIL_FROM=rvpark@crookedriverranch.com     # HOA-owned address; all system emails come from here
