---
/**
 * AvailabilityMap — guest-facing "Check Availability" map.
 *
 * Reuses the ParkMapPolygons.astro pattern: a server-rendered base <img>
 * with an inline SVG overlay of normalised (0–1) polygons, scaled into a
 * 0..1000 viewBox. The difference from ParkMapPolygons is behavioural:
 *
 *   • A search form (arrival / departure / RV length / slides / site type)
 *     sits above the map.
 *   • On search, a tiny inline script calls the same-origin proxy
 *     (/api/availability) which fetches Rimrock server-side, then repaints
 *     each polygon available (green) / unavailable (grey).
 *   • Clicking an AVAILABLE site opens the Firefly reservation deep-link in
 *     a new tab. Unavailable / blocked sites are dimmed and not reservable.
 *   • NO pricing is shown anywhere (deliberate — this page is availability
 *     only; rates live on the booking flow).
 *
 * Framework-light on purpose: no React island, ~2 KB of inline JS, matching
 * the existing polygon map. The map ALWAYS renders from Supabase park_sites
 * so the page works even when the Rimrock API is unreachable — availability
 * is layered on top only when the proxy responds.
 *
 * The base image is the CSP-allowed Supabase park_maps active image (same
 * image the polygons were normalised against, so overlay + image stay
 * aligned). The proxy also exposes the RR base blob same-origin, but using
 * the Supabase image keeps the overlay perfectly registered.
 */

const SVG_SCALE = 1000;

interface ParkMap {
  image_url: string;
  title: string;
  natural_width: number;
  natural_height: number;
}

interface SiteRow {
  site_number: string;
  loop: string;
  site_type: string | null;
  length_feet: number | null;
  amp_service: number | null;
  pull_through: boolean;
  status: string;
  map_polygon: [number, number][] | null;
  firefly_deep_link: string | null;
}

export interface Props {
  parkMap: ParkMap;
  /** Sites that carry a polygon (caller pre-filters). */
  sites: SiteRow[];
}

const { parkMap, sites } = Astro.props;

const FIREFLY_FALLBACK = 'https://app.fireflyreservations.com/reserve/property/CROOKEDRIVERRANCHRVPARK';

function pointsFor(poly: [number, number][]): string {
  return poly.map(([x, y]) => `${(x * SVG_SCALE).toFixed(1)},${(y * SVG_SCALE).toFixed(1)}`).join(' ');
}
function centroidFor(poly: [number, number][]): { x: number; y: number } {
  const x = poly.reduce((s, p) => s + p[0], 0) / poly.length;
  const y = poly.reduce((s, p) => s + p[1], 0) / poly.length;
  return { x: x * SVG_SCALE, y: y * SVG_SCALE };
}

// Dates for the form defaults / min attributes (America park is fine with
// the server's date; guests can change it).
const today = new Date();
const tomorrow = new Date(today.getTime() + 24 * 60 * 60 * 1000);
const iso = (d: Date) => d.toISOString().slice(0, 10);
const todayIso = iso(today);
const tomorrowIso = iso(tomorrow);

const polygons = sites.map((s) => {
  const poly = s.map_polygon as [number, number][];
  const centroid = centroidFor(poly);
  // status==='available' sites participate in availability painting; any
  // other status (camp_host, staff_only, maintenance, reserved, seasonal_
  // closed) is never guest-reservable → rendered permanently blocked.
  const bookable = s.status === 'available';
  const payload = {
    code: s.site_number,
    loop: s.loop,
    type: s.site_type,
    length: s.length_feet,
    amp: s.amp_service,
    pullThrough: s.pull_through,
    status: s.status,
    firefly: s.firefly_deep_link || FIREFLY_FALLBACK,
  };
  return {
    code: s.site_number,
    points: pointsFor(poly),
    centroid,
    initialClass: bookable ? 'av-unknown' : 'av-blocked',
    dataSite: JSON.stringify(payload).replace(/'/g, '&#39;'),
  };
});
---

<div class="av-tool">
  <form class="av-form" id="avForm" novalidate>
    <div class="av-form-grid">
      <div class="fg">
        <label for="avFrom">Arrival</label>
        <input type="date" id="avFrom" name="from" value={todayIso} min={todayIso} required />
      </div>
      <div class="fg">
        <label for="avTo">Departure</label>
        <input type="date" id="avTo" name="to" value={tomorrowIso} min={tomorrowIso} required />
      </div>
      <div class="fg">
        <label for="avType">Site type</label>
        <select id="avType" name="type">
          <option value="any">Any type</option>
          <option value="full-hookup">Full hookup</option>
          <option value="water_electric">Water + electric</option>
          <option value="tent_or_dry">Tent + dry camp</option>
          <option value="dry">Dry (no hookups)</option>
          <option value="tent">Tent</option>
        </select>
      </div>
      <div class="fg">
        <label for="avRig">RV length (ft)</label>
        <input type="number" id="avRig" name="rigLengthFt" min="1" max="99" inputmode="numeric" placeholder="e.g. 32" />
      </div>
      <div class="fg">
        <label for="avSlides">Slides</label>
        <select id="avSlides" name="slides">
          <option value="any">Doesn't matter</option>
          <option value="yes">Yes</option>
          <option value="no">No</option>
        </select>
      </div>
      <div class="fg av-form-submit">
        <label aria-hidden="true">&nbsp;</label>
        <button type="submit" class="btn-sub" id="avSubmit">Check availability</button>
      </div>
    </div>
    <div class="av-status" id="avStatus" role="status" aria-live="polite">
      Pick your dates and search to see what's open. Green sites are available for your dates.
    </div>
  </form>

  <div class="av-legend" aria-hidden="true">
    <span class="av-legend-item"><span class="av-swatch av-swatch--avail"></span>Available</span>
    <span class="av-legend-item"><span class="av-swatch av-swatch--unavail"></span>Unavailable</span>
    <span class="av-legend-item"><span class="av-swatch av-swatch--filtered"></span>Other site types</span>
    <span class="av-legend-item"><span class="av-swatch av-swatch--unknown"></span>Search to check</span>
    <span class="av-legend-item"><span class="av-swatch av-swatch--blocked"></span>Not bookable online</span>
  </div>

  <div class="av-freshness" role="note" aria-label="Live site map status">
    <div class="av-freshness-heading">
      <span class="av-freshness-badge">Live map beta</span>
      <span class="av-freshness-stamp" id="avFreshness" role="status" aria-live="polite" hidden></span>
    </div>
    <p class="av-freshness-caveat">
      <strong>This live site map is still under construction.</strong>
      Site details and availability may not be perfect. Final availability is shown when you continue to Firefly to book.
      We are actively improving this feature — stay tuned.
    </p>
  </div>

  <div class="av-wrap" data-natural-w={parkMap.natural_width} data-natural-h={parkMap.natural_height}>
    <img
      src={parkMap.image_url}
      alt={`Map of Crooked River Ranch RV Park — ${parkMap.title}`}
      class="av-bg"
      width={parkMap.natural_width}
      height={parkMap.natural_height}
      loading="eager"
      decoding="async"
    />
    <svg
      class="av-overlay"
      viewBox={`0 0 ${SVG_SCALE} ${SVG_SCALE}`}
      preserveAspectRatio="none"
      aria-label="Interactive availability map"
    >
      {polygons.map((p) => (
        <g class="av-site" data-site-code={p.code} data-site={p.dataSite} role="button" tabindex="0" aria-label={`Site ${p.code}`}>
          <polygon points={p.points} class={`av-poly ${p.initialClass}`} />
          <text
            x={p.centroid.x}
            y={p.centroid.y}
            class="av-label"
            text-anchor="middle"
            dominant-baseline="central"
          >{p.code}</text>
        </g>
      ))}
    </svg>

    <div class="av-popover" role="dialog" aria-hidden="true" hidden>
      <h3 class="av-pop-title"></h3>
      <div class="av-pop-status"></div>
      <div class="av-pop-chips"></div>
      <div class="av-pop-actions">
        <a class="av-pop-book" href="#" target="_blank" rel="noopener noreferrer">Reserve on Firefly →</a>
        <div class="av-pop-msg"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var tool = document.currentScript.closest('.av-tool') || document.querySelector('.av-tool');
    if (!tool) return;
    var form = tool.querySelector('#avForm');
    var statusEl = tool.querySelector('#avStatus');
    var submitBtn = tool.querySelector('#avSubmit');
    var wrap = tool.querySelector('.av-wrap');
    var popover = tool.querySelector('.av-popover');
    if (!form || !wrap || !popover) return;

    var sites = Array.prototype.slice.call(wrap.querySelectorAll('.av-site'));
    var isTouch = matchMedia('(hover: none)').matches;
    var activeEl = null;
    var pinned = false;

    function parseData(el) {
      try { return JSON.parse(el.dataset.site.replace(/&#39;/g, "'")); } catch (e) { return null; }
    }
    function siteState(el) {
      var poly = el.querySelector('.av-poly');
      if (poly.classList.contains('av-avail')) return 'avail';
      if (poly.classList.contains('av-unavail')) return 'unavail';
      if (poly.classList.contains('av-filtered')) return 'filtered';
      if (poly.classList.contains('av-blocked')) return 'blocked';
      return 'unknown';
    }
    function fmtDate(s) {
      // s = YYYY-MM-DD → "Jul 17"
      var parts = s.split('-');
      if (parts.length !== 3) return s;
      var d = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    // ---- Freshness stamp --------------------------------------------------
    // The proxy passes through Rimrock's lastSyncedAt (ISO timestamp of its
    // last Firefly sync) when RR provides it. Older RR deploys omit the field
    // → the stamp simply stays hidden (the caveat line always shows).
    var freshEl = tool.querySelector('#avFreshness');
    function relTime(isoStr) {
      var t = Date.parse(isoStr);
      if (isNaN(t)) return null;
      var s = Math.max(0, Math.round((Date.now() - t) / 1000));
      if (s < 60) return 'just now';
      var m = Math.round(s / 60);
      if (m < 60) return m + (m === 1 ? ' minute' : ' minutes') + ' ago';
      var h = Math.round(m / 60);
      if (h < 24) return h + (h === 1 ? ' hour' : ' hours') + ' ago';
      var d = Math.round(h / 24);
      return d + (d === 1 ? ' day' : ' days') + ' ago';
    }
    function setFreshness(isoStr) {
      if (!freshEl) return;
      var rel = isoStr ? relTime(isoStr) : null;
      if (rel) {
        freshEl.textContent = 'Availability updated ' + rel + '.';
        freshEl.hidden = false;
      } else {
        freshEl.textContent = '';
        freshEl.hidden = true;
      }
    }

    // ---- Popover ----------------------------------------------------------
    function populate(data, state, reason) {
      popover.querySelector('.av-pop-title').textContent = 'Site ' + (data.code || '');

      var st = popover.querySelector('.av-pop-status');
      var labels = {
        avail: 'Available', unavail: 'Unavailable',
        filtered: 'Other site type',
        blocked: 'Not bookable online', unknown: 'Search dates to check',
      };
      st.textContent = labels[state] || '';
      st.className = 'av-pop-status av-pop-status--' + state;

      var chips = popover.querySelector('.av-pop-chips');
      chips.innerHTML = '';
      function chip(t) { var e = document.createElement('span'); e.className = 'av-chip'; e.textContent = t; chips.appendChild(e); }
      if (data.loop) chip('Loop ' + data.loop);
      if (data.type) chip(data.type);
      if (data.length) chip(data.length + ' ft');
      if (data.amp) chip(data.amp + ' amp');
      if (data.pullThrough) chip('pull-through');

      var book = popover.querySelector('.av-pop-book');
      var msg = popover.querySelector('.av-pop-msg');
      if (state === 'avail') {
        book.href = data.firefly;
        book.hidden = false;
        msg.hidden = true;
      } else {
        book.hidden = true;
        msg.hidden = false;
        if (state === 'unavail') msg.textContent = reason || 'Not available for the selected dates.';
        else if (state === 'filtered') msg.textContent = 'Change the site-type filter above to check this site.';
        else if (state === 'blocked') msg.textContent = 'Call the office at 541-923-1441 to book this site.';
        else msg.textContent = 'Pick your dates above and search to check this site.';
      }
    }
    function showAt(clientX, clientY) {
      var rect = wrap.getBoundingClientRect();
      var x = clientX - rect.left, y = clientY - rect.top;
      var popW = 250, popH = popover.offsetHeight || 150;
      popover.style.left = Math.min(Math.max(x + 14, 8), rect.width - popW - 8) + 'px';
      popover.style.top = Math.min(Math.max(y - 10, 8), rect.height - popH - 8) + 'px';
      popover.hidden = false;
      popover.setAttribute('aria-hidden', 'false');
    }
    function hide() {
      popover.hidden = true;
      popover.setAttribute('aria-hidden', 'true');
      activeEl = null;
      pinned = false;
    }
    function reasonFor(el) { return el.dataset.reason || ''; }

    // Desktop hover.
    wrap.addEventListener('pointermove', function (e) {
      if (isTouch) return;
      var el = e.target.closest ? e.target.closest('.av-site') : null;
      if (el) {
        if (el !== activeEl) {
          activeEl = el;
          populate(parseData(el), siteState(el), reasonFor(el));
        }
        showAt(e.clientX, e.clientY);
      } else if (activeEl) {
        hide();
      }
    });
    wrap.addEventListener('pointerleave', function () { if (!isTouch) hide(); });

    // Click: available → open Firefly; otherwise show info popover.
    function activate(el, clientX, clientY) {
      var data = parseData(el);
      var state = siteState(el);
      if (state === 'avail' && data) {
        window.open(data.firefly, '_blank', 'noopener');
        return;
      }
      activeEl = el;
      pinned = true;
      populate(data, state, reasonFor(el));
      if (typeof clientX === 'number') {
        showAt(clientX, clientY);
      } else {
        var poly = el.querySelector('polygon');
        var r = poly.getBoundingClientRect();
        showAt(r.left + r.width / 2, r.top + r.height / 2);
      }
    }
    wrap.addEventListener('click', function (e) {
      if (e.target.closest('.av-popover')) return;
      var el = e.target.closest ? e.target.closest('.av-site') : null;
      if (!el) return;
      e.preventDefault();
      activate(el, isTouch ? undefined : e.clientX, e.clientY);
    });
    // Keyboard: Enter/Space on a focused site.
    wrap.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      var el = e.target.closest ? e.target.closest('.av-site') : null;
      if (!el) return;
      e.preventDefault();
      activate(el);
    });
    document.addEventListener('click', function (e) {
      if (!pinned) return;
      if (e.target.closest('.av-popover') || e.target.closest('.av-site')) return;
      hide();
    });

    // ---- Repaint ----------------------------------------------------------
    function resetToUnknown() {
      sites.forEach(function (el) {
        var poly = el.querySelector('.av-poly');
        if (poly.classList.contains('av-blocked')) return; // stays blocked
        poly.classList.remove('av-avail', 'av-unavail', 'av-filtered');
        poly.classList.add('av-unknown');
        el.removeAttribute('data-reason');
      });
    }
    function matchesSelectedType(data, selectedType) {
      if (!selectedType || selectedType === 'any') return true;
      var type = data && data.type ? String(data.type) : '';
      if (selectedType === 'full-hookup') {
        return type === 'full-hookup' || type === 'pull-through-full' || type === 'pull-in-full';
      }
      if (selectedType === 'water_electric') return type === 'water-electric';
      if (selectedType === 'tent_or_dry') return type === 'tent' || type === 'dry-camp';
      if (selectedType === 'dry') return type === 'dry-camp';
      if (selectedType === 'tent') return type === 'tent';
      return true;
    }
    function resultNoun(count, selectedType) {
      var singular = count === 1;
      var labels = {
        'full-hookup': singular ? 'full-hookup site' : 'full-hookup sites',
        water_electric: singular ? 'water + electric site' : 'water + electric sites',
        tent_or_dry: singular ? 'tent or dry-camp site' : 'tent or dry-camp sites',
        dry: singular ? 'dry-camp site' : 'dry-camp sites',
        tent: singular ? 'tent site' : 'tent sites',
      };
      return labels[selectedType] || (singular ? 'site' : 'sites');
    }
    function paint(list) {
      var byCode = {};
      list.forEach(function (s) { byCode[s.code] = s; });
      var availCount = 0;
      var selectedType = form.type.value || 'any';
      sites.forEach(function (el) {
        var poly = el.querySelector('.av-poly');
        if (poly.classList.contains('av-blocked')) return;
        var data = parseData(el);
        var code = el.getAttribute('data-site-code');
        var rec = byCode[code];
        poly.classList.remove('av-unknown', 'av-avail', 'av-unavail', 'av-filtered');
        if (!matchesSelectedType(data, selectedType)) {
          poly.classList.add('av-filtered');
          el.removeAttribute('data-reason');
          return;
        }
        if (rec && rec.available) {
          poly.classList.add('av-avail');
          el.removeAttribute('data-reason');
          availCount++;
        } else {
          poly.classList.add('av-unavail');
          if (rec && rec.reason) el.setAttribute('data-reason', rec.reason);
          else el.removeAttribute('data-reason');
        }
      });
      return availCount;
    }

    function setStatus(msg, kind) {
      statusEl.textContent = msg;
      statusEl.className = 'av-status' + (kind ? ' av-status--' + kind : '');
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      hide();
      var from = form.from.value;
      var to = form.to.value;
      if (!from || !to) { setStatus('Please choose both an arrival and a departure date.', 'warn'); return; }
      if (to <= from) { setStatus('Your departure date must be after your arrival date.', 'warn'); return; }

      var qs = new URLSearchParams({ from: from, to: to });
      if (form.type.value && form.type.value !== 'any') qs.set('type', form.type.value);
      if (form.rigLengthFt.value) qs.set('rigLengthFt', form.rigLengthFt.value);
      if (form.slides.value && form.slides.value !== 'any') qs.set('slides', form.slides.value);

      submitBtn.disabled = true;
      submitBtn.textContent = 'Checking…';
      setStatus('Checking availability…');

      fetch('/api/availability?' + qs.toString(), { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data || !data.ok) {
            resetToUnknown();
            setFreshness(null);
            setStatus(
              (data && data.reason ? data.reason + ' ' : '') +
              'Live availability is temporarily unavailable — please call the office at 541-923-1441 or try again shortly.',
              'warn'
            );
            return;
          }
          var n = paint(data.sites || []);
          setFreshness(data.lastSyncedAt);
          var range = fmtDate(from) + ' – ' + fmtDate(to);
          var noun = resultNoun(n, form.type.value);
          if (n === 0) {
            setStatus('No ' + noun + ' match those dates for ' + range + '. Try different dates or call 541-923-1441.', 'warn');
          } else {
            setStatus(n + ' ' + noun + (n === 1 ? ' is' : ' are') + ' available for ' + range + '. Tap a green site to reserve on Firefly.', 'ok');
          }
        })
        .catch(function () {
          resetToUnknown();
          setFreshness(null);
          setStatus('Live availability is temporarily unavailable — please call the office at 541-923-1441 or try again shortly.', 'warn');
        })
        .finally(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Check availability';
        });
    });
  })();
</script>

<style>
  .av-tool { --av-green: #4A7C59; --av-grey: #9a938a; }

  .av-form {
    background: var(--cream, #F5EFE6);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 4px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1.25rem;
  }
  .av-form-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.85rem;
    align-items: end;
  }
  .av-form .fg { margin-bottom: 0; }
  .av-form-submit .btn-sub { white-space: nowrap; }
  @media (max-width: 900px) {
    .av-form-grid { grid-template-columns: 1fr 1fr; }
    .av-form-submit { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .av-form-grid { grid-template-columns: 1fr; }
  }

  .av-status {
    margin-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--muted, #665040);
    padding: 0.6rem 0.85rem;
    background: var(--sand, #EDE5D8);
    border-left: 3px solid rgba(0,0,0,0.15);
    border-radius: 3px;
  }
  .av-status--ok   { border-left-color: var(--av-green); color: #2f5238; background: rgba(74,124,89,0.08); }
  .av-status--warn { border-left-color: var(--rust, #C4622D); color: #7a3a18; background: rgba(196,98,45,0.07); }

  .av-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.25rem;
    margin-bottom: 0.85rem;
    font-size: 0.8rem;
    color: var(--muted, #665040);
  }
  .av-legend-item { display: inline-flex; align-items: center; gap: 0.4rem; }

  .av-freshness {
    margin: -0.35rem 0 0.85rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid rgba(47, 111, 96, 0.18);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(224, 239, 234, 0.62));
    box-shadow: 0 10px 30px rgba(23, 79, 66, 0.06);
    color: var(--muted, #665040);
    backdrop-filter: blur(12px);
  }
  .av-freshness-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.7rem;
    margin-bottom: 0.35rem;
  }
  .av-freshness-badge {
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: #174f42;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.4;
    text-transform: uppercase;
  }
  .av-freshness-stamp {
    color: #2f5238;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .av-freshness-stamp[hidden] { display: none; }
  .av-freshness-caveat {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
  }
  .av-freshness-caveat strong { color: #173c34; }
  .av-swatch { width: 14px; height: 14px; border-radius: 3px; display: inline-block; border: 1px solid rgba(0,0,0,0.15); }
  .av-swatch--avail   { background: rgba(74,124,89,0.55); border-color: var(--av-green); }
  .av-swatch--unavail { background: rgba(154,147,138,0.4); border-color: var(--av-grey); }
  .av-swatch--filtered { background: rgba(255,255,255,0.18); border-color: rgba(102,80,64,0.42); }
  .av-swatch--unknown { background: rgba(196,98,45,0.22); border-color: var(--rust, #C4622D); }
  .av-swatch--blocked { background: rgba(100,100,100,0.25); border-color: #555; }

  .av-wrap {
    position: relative;
