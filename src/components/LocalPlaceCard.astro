---
/**
 * LocalPlaceCard — renders a local place from a local_places row.
 *
 * Uses Google's cached_data for name, rating, address, photo, hours, and
 * link to Maps. Falls back to name_override when Google data is missing.
 *
 * Photos go through our /api/place-photo proxy so the Places API key
 * stays server-side (the previous implementation embedded the key in
 * the rendered HTML — a leaked-secret + restriction-mismatch bug).
 */
import type { LocalPlace } from '@lib/area-guide';

export interface Props {
  place: LocalPlace;
}

const { place } = Astro.props;
const g = place.cached_data ?? {};

// Photos load progressively client-side via the shared Google-place-photo
// loader (public/scripts/production-v3.js). It refreshes the current photo
// through /api/place-photo?place=<id>&format=json — the stored photo name can
// expire, but the stable Place ID recovers a current one — shows a placeholder
// until it arrives, and renders Google's required author attribution. The
// loader is only offered when the place has a cached photo; otherwise the
// category emoji fallback stands in.
const photo = g.photos?.[0];
const googlePlaceId = photo?.name && place.google_place_id ? place.google_place_id : null;
const categoryEmoji =
  place.category === 'restaurant' ? '🍽'
  : place.category === 'brewery' ? '🍺'
  : place.category === 'coffee' ? '☕'
  : place.category === 'attraction' ? '🏞'
  : '📍';

const displayName = g.displayName?.text ?? place.name_override ?? '(Unnamed place)';
const mapsHref = g.googleMapsUri ?? place.cached_data?.googleMapsUri ?? null;
const rating = g.rating;
const ratingCount = g.userRatingCount;
const address = g.formattedAddress;
const blurb = place.our_description ?? g.editorialSummary?.text ?? null;
const openNow = g.regularOpeningHours?.openNow;
---
<div class="lp-card">
  <div
    class:list={['lp-card-vis', googlePlaceId && 'crr-google-place-photo']}
    data-google-place-photo={googlePlaceId || undefined}
    data-photo-width="600"
  >
    {googlePlaceId ? (
      <>
        <span class="crr-photo-placeholder" aria-hidden="true">{categoryEmoji}</span>
        <img data-google-photo-image alt={displayName} loading="lazy" />
        <small class="crr-google-photo-attribution" data-google-photo-attribution hidden></small>
      </>
    ) : (
      <div class="lp-card-fallback">
        <span>{categoryEmoji}</span>
      </div>
    )}
    {place.featured && <div class="lp-card-badge">Editor's pick</div>}
  </div>
  <div class="lp-card-body">
    <div class="lp-card-cat">{place.category.replace('_', ' ')}</div>
    <div class="lp-card-title">{displayName}</div>
    {rating && (
      <div class="lp-card-rating">
        <span style="color:#F59E0B;">{'★'.repeat(Math.round(rating))}{'☆'.repeat(5 - Math.round(rating))}</span>
        <span style="color:var(--muted);">{rating.toFixed(1)}{ratingCount ? ` (${ratingCount.toLocaleString()})` : ''}</span>
      </div>
    )}
    {address && <div class="lp-card-address">{address}</div>}
    {blurb && <p class="lp-card-blurb">{blurb}</p>}
    {openNow !== undefined && (
      <div class={`lp-card-hours ${openNow ? 'is-open' : 'is-closed'}`}>
        {openNow ? 'Open now' : 'Closed'}
      </div>
    )}
    <div class="lp-card-actions">
      {mapsHref && (
        <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="lp-card-link">
          Directions &rarr;
        </a>
      )}
      {g.websiteUri && (
        <a href={g.websiteUri} target="_blank" rel="noopener noreferrer" class="lp-card-link">
          Website &rarr;
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .lp-card {
    background: var(--crr-glass);
    border: 1px solid rgba(255,255,255,.72);
    border-radius: 25px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    box-shadow: 0 18px 46px rgba(17,53,44,.08);
    backdrop-filter: blur(18px);
  }
  .lp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 58px rgba(17,53,44,.14);
    border-color: rgba(35,107,88,.35);
  }
  .lp-card-vis {
    position: relative;
    aspect-ratio: 16 / 10;
    background: linear-gradient(135deg, #cfe5de, #7eaa9b);
    overflow: hidden;
  }
  .lp-card-vis img { width: 100%; height: 100%; object-fit: cover; }
  .lp-card-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    font-size: 3rem;
  }
  .lp-card-badge {
    position: absolute;
    top: .7rem;
    left: .7rem;
    background: rgba(13,36,30,.68);
    color: #fff;
    font-size: .68rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .22rem .55rem;
    border: 1px solid rgba(255,255,255,.42);
    border-radius: 999px;
    font-weight: 500;
  }
  .lp-card-body {
    padding: 1.3rem 1.35rem 1.45rem;
    display: flex;
    flex-direction: column;
    gap: .4rem;
    flex: 1;
  }
  .lp-card-cat {
    font-size: .66rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--crr-forest);
    font-weight: 800;
  }
  .lp-card-title {
    font-family: Manrope, sans-serif;
    font-size: 1.25rem;
    color: var(--crr-ink);
    line-height: 1.2;
  }
  .lp-card-rating {
    font-size: .8rem;
    display: flex;
    gap: .5rem;
    align-items: center;
  }
  .lp-card-address {
    font-size: .8rem;
    color: var(--muted);
    line-height: 1.4;
  }
  .lp-card-blurb {
    color: var(--muted);
    font-size: .87rem;
    line-height: 1.5;
    margin: .3rem 0 0;
  }
  .lp-card-hours {
    font-size: .78rem;
    margin-top: .35rem;
    font-weight: 500;
  }
  .lp-card-hours.is-open { color: var(--crr-forest); }
  .lp-card-hours.is-closed { color: #8B1A1A; }
  .lp-card-actions {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: .6rem;
  }
  .lp-card-link {
    font-size: .82rem;
    color: var(--crr-forest);
    text-decoration: none;
    font-weight: 800;
  }
  .lp-card-link:hover { text-decoration: underline; }
</style>
