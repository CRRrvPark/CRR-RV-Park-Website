---
/**
 * ParkMapPolygons — server-rendered SVG polygon overlay for the park map.
 *
 * Reads the active park_maps row + every published park_sites row that has
 * a map_polygon, then renders a base `<img>` with an SVG overlay. Each
 * polygon is an `<a>` link wrapping a `<polygon>` element so the click
 * target is native browser behavior — no JS needed for navigation.
 *
 * Interaction model (matches the plan the owner signed off on):
 *   • Desktop hover → popover card (CSS + JS)
 *   • Desktop click → navigate to /sites/[code] detail page
 *   • Mobile tap   → popover card (the polygon's anchor preventDefault on
 *     first tap); "Site info →" link inside popover navigates to detail
 *
 * Status drives polygon color via `ppm-poly--<status>` CSS classes. The
 * six statuses match park_sites.status CHECK constraint:
 *   available / camp_host / staff_only / maintenance / reserved / seasonal_closed
 *
 * Caller is responsible for the decision "show this component at all"
 * (i.e., only render when park_maps has an active row + at least one
 * polygon exists). Fallback is the caller's job.
 */

import { serverClient } from '@lib/supabase';

interface ParkMap {
  id: string;
  slug: string;
  title: string;
  image_url: string;
  natural_width: number;
  natural_height: number;
}

interface SiteRow {
  id: string;
  site_number: string;
  loop: string;
  site_type: string | null;
  length_feet: number | null;
  amp_service: number | null;
  pull_through: boolean;
  nightly_rate: number | null;
  status: string;
  status_note: string | null;
  map_polygon: [number, number][] | null;
  firefly_deep_link: string | null;
}

export interface Props {
  parkMap: ParkMap;
  /** Site rows that have a polygon. Caller pre-filters so empty-polygon
   *  rows aren't passed in. */
  sites: SiteRow[];
}

const { parkMap, sites } = Astro.props;

// Build SVG `points` strings server-side from normalised polygon data.
// SVG viewBox is 0 0 1000 1000 (SVG_SCALE); polygons store 0-1 coords so
// multiplying by 1000 lands us in the viewBox's coordinate space. The
// overlay stretches to match the <img>'s displayed size via
// preserveAspectRatio="none" so clicks always align to the visible image.
const SVG_SCALE = 1000;
function pointsFor(poly: [number, number][]): string {
  return poly.map(([x, y]) => `${(x * SVG_SCALE).toFixed(1)},${(y * SVG_SCALE).toFixed(1)}`).join(' ');
}
function centroidFor(poly: [number, number][]): { x: number; y: number } {
  const x = poly.reduce((s, p) => s + p[0], 0) / poly.length;
  const y = poly.reduce((s, p) => s + p[1], 0) / poly.length;
  return { x: x * SVG_SCALE, y: y * SVG_SCALE };
}

const FIREFLY_FALLBACK = 'https://app.fireflyreservations.com/reserve/property/CROOKEDRIVERRANCHRVPARK';

// Precompute everything needed to render per-site so the template stays
// simple and stays purely server-rendered HTML.
const polygons = sites.map((s) => {
  const poly = s.map_polygon as [number, number][];
  const bookUrl = s.firefly_deep_link || FIREFLY_FALLBACK;
  const canBook = s.status === 'available' && s.firefly_deep_link !== null;
  const centroid = centroidFor(poly);
  // Popover payload — serialised into data-site so the tiny inline script
  // can populate the floating card without an extra network call.
  const popover = {
    code: s.site_number,
    loop: s.loop,
    type: s.site_type,
    length: s.length_feet,
    amp: s.amp_service,
    pullThrough: s.pull_through,
    rate: s.nightly_rate,
    status: s.status,
    statusNote: s.status_note,
    detailUrl: `/sites/${encodeURIComponent(s.site_number)}`,
    bookUrl: canBook ? bookUrl : null,
    phone: s.status === 'staff_only' ? '541-923-1441' : null,
  };
  return {
    siteCode: s.site_number,
    points: pointsFor(poly),
    centroid,
    status: s.status,
    detailUrl: `/sites/${encodeURIComponent(s.site_number)}`,
    dataSite: JSON.stringify(popover).replace(/'/g, '&#39;'),
  };
});
---

<div
  class="ppm-wrap"
  data-natural-w={parkMap.natural_width}
  data-natural-h={parkMap.natural_height}
>
  <img
    src={parkMap.image_url}
    alt={`Map of Crooked River Ranch RV Park — ${parkMap.title}`}
    class="ppm-bg"
    width={parkMap.natural_width}
    height={parkMap.natural_height}
    loading="eager"
    decoding="async"
  />
  <svg
    class="ppm-overlay"
    viewBox={`0 0 ${SVG_SCALE} ${SVG_SCALE}`}
    preserveAspectRatio="none"
    aria-label="Interactive park site map"
  >
    {polygons.map((p) => (
      <a
        href={p.detailUrl}
        class="ppm-link"
        data-site-code={p.siteCode}
        data-site={p.dataSite}
        aria-label={`Site ${p.siteCode}`}
      >
        <polygon
          points={p.points}
          class={`ppm-poly ppm-poly--${p.status}`}
        />
        <text
          x={p.centroid.x}
          y={p.centroid.y}
          class="ppm-label"
          text-anchor="middle"
          dominant-baseline="central"
        >{p.siteCode}</text>
      </a>
    ))}
  </svg>

  {/* Single floating popover, driven by the inline script below. Hidden
     by default; positioned JS-side on hover/tap and shown. */}
  <div class="ppm-popover" role="dialog" aria-hidden="true" hidden>
    <h3 class="ppm-pop-title"></h3>
    <div class="ppm-pop-status"></div>
    <div class="ppm-pop-note"></div>
    <div class="ppm-pop-chips"></div>
    <div class="ppm-pop-actions">
      <a class="ppm-pop-info" href="#">Site info →</a>
      <a class="ppm-pop-book" href="#" target="_blank" rel="noopener noreferrer">Book this site →</a>
      <a class="ppm-pop-call" href="tel:5419231441">Call 541-923-1441</a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    // Minimal popover logic. No framework; ~1 KB of inline JS.
    //
    // Desktop: hover polygon → popover appears near cursor, click polygon
    //   (which is wrapped in an <a href>) navigates to the detail page.
    // Mobile:  tap polygon → preventDefault the anchor's first tap and
    //   show the popover anchored near the polygon's label. The popover
    //   itself has a "Site info →" link (same detail page) + "Book" link.
    //   Tapping outside the popover closes it. Subsequent tap on the same
    //   polygon's info link navigates normally.
    const wrap = document.currentScript.previousElementSibling || document.querySelector('.ppm-wrap');
    if (!wrap || !wrap.classList.contains('ppm-wrap')) return;
    const popover = wrap.querySelector('.ppm-popover');
    if (!popover) return;

    const isTouch = matchMedia('(hover: none)').matches;
    let activeLink = null;
    let pinnedOnMobile = false;

    function populate(data) {
      popover.querySelector('.ppm-pop-title').textContent = 'Site ' + (data.code || '');
      const status = popover.querySelector('.ppm-pop-status');
      const statusLabels = {
        available: 'Available',
        camp_host: 'Camp Host — permanent site',
        staff_only: 'Staff booking only',
        maintenance: 'Maintenance',
        reserved: 'Reserved',
        seasonal_closed: 'Closed for season',
      };
      status.textContent = statusLabels[data.status] || '';
      status.className = 'ppm-pop-status ppm-pop-status--' + data.status;

      const note = popover.querySelector('.ppm-pop-note');
      note.textContent = data.statusNote || '';
      note.hidden = !data.statusNote;

      const chips = popover.querySelector('.ppm-pop-chips');
      chips.innerHTML = '';
      const ch = (t) => { const el = document.createElement('span'); el.className = 'ppm-chip'; el.textContent = t; return el; };
      if (data.loop) chips.appendChild(ch('Loop ' + data.loop));
      if (data.type) chips.appendChild(ch(data.type));
      if (data.length) chips.appendChild(ch(data.length + 'ft'));
      if (data.amp) chips.appendChild(ch(data.amp + 'amp'));
      if (data.pullThrough) chips.appendChild(ch('pull-through'));
      if (data.rate) chips.appendChild(ch('$' + data.rate + '/nt'));

      const info = popover.querySelector('.ppm-pop-info');
      info.href = data.detailUrl;

      const book = popover.querySelector('.ppm-pop-book');
      const call = popover.querySelector('.ppm-pop-call');
      if (data.bookUrl) {
        book.href = data.bookUrl;
        book.hidden = false;
        call.hidden = true;
      } else if (data.phone) {
        book.hidden = true;
        call.hidden = false;
      } else {
        book.hidden = true;
        call.hidden = true;
      }
    }

    function showAt(clientX, clientY) {
      const rect = wrap.getBoundingClientRect();
      const x = clientX - rect.left;
      const y = clientY - rect.top;
      const popW = 260;
      const popH = popover.offsetHeight || 180;
      // Prefer to the right + above the cursor; clamp inside the wrap.
      const lx = Math.min(Math.max(x + 14, 8), rect.width - popW - 8);
      const ly = Math.min(Math.max(y - 10, 8), rect.height - popH - 8);
      popover.style.left = lx + 'px';
      popover.style.top = ly + 'px';
      popover.hidden = false;
      popover.setAttribute('aria-hidden', 'false');
    }

    function hide() {
      popover.hidden = true;
      popover.setAttribute('aria-hidden', 'true');
      activeLink = null;
      pinnedOnMobile = false;
    }

    wrap.addEventListener('pointerenter', (e) => {
      if (isTouch) return;
      const link = e.target.closest('.ppm-link');
      if (!link) return;
      activeLink = link;
      try { populate(JSON.parse(link.dataset.site.replace(/&#39;/g, "'"))); } catch {}
      showAt(e.clientX, e.clientY);
    }, true);

    wrap.addEventListener('pointermove', (e) => {
      if (isTouch || !activeLink) return;
      showAt(e.clientX, e.clientY);
    });

    wrap.addEventListener('pointerleave', () => {
      if (isTouch) return;
      hide();
    });

    // Mobile: tap polygon → show popover (preventDefault navigation).
    wrap.addEventListener('click', (e) => {
      if (!isTouch) return;
      const link = e.target.closest('.ppm-link');
      if (!link) return;
      if (e.target.closest('.ppm-popover')) return;  // let in-popover links click
      // First tap on polygon → show popover, don't navigate.
      // (Navigation happens via the "Site info" link inside the popover.)
      e.preventDefault();
      activeLink = link;
      try { populate(JSON.parse(link.dataset.site.replace(/&#39;/g, "'"))); } catch {}
      pinnedOnMobile = true;
      const polygon = link.querySelector('polygon');
      const r = polygon.getBoundingClientRect();
      showAt(r.left + r.width / 2, r.top + r.height / 2);
    }, true);

    // Tap outside on mobile → close.
    document.addEventListener('click', (e) => {
      if (!isTouch || !pinnedOnMobile) return;
      if (e.target.closest('.ppm-popover')) return;
      if (e.target.closest('.ppm-link')) return;
      hide();
    });
  })();
</script>

<style>
  .ppm-wrap {
    position: relative;
    width: 100%;
    background: var(--sand, #f5efe3);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.07);
  }
  .ppm-bg {
    display: block;
    width: 100%;
    height: auto;
  }
  .ppm-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .ppm-link, .ppm-overlay polygon, .ppm-overlay text {
    pointer-events: auto;
  }
  .ppm-link { outline: none; }
  .ppm-link:focus-visible .ppm-poly { stroke-width: 3; stroke: var(--rust); }

  .ppm-poly {
    fill: rgba(196, 98, 45, 0.22);
    stroke: var(--rust, #C4622D);
    stroke-width: 1.2;
    transition: fill 120ms ease, stroke-width 120ms ease;
    cursor: pointer;
  }
  .ppm-poly:hover { fill: rgba(196, 98, 45, 0.5); stroke-width: 2.2; }

  /* Status variants */
  .ppm-poly--camp_host   { fill: rgba(212, 168, 83, 0.35); stroke: var(--gold, #D4A853); }
  .ppm-poly--camp_host:hover { fill: rgba(212, 168, 83, 0.6); }
  .ppm-poly--staff_only  { fill: rgba(100, 100, 100, 0.25); stroke: #555; stroke-dasharray: 4 3; }
  .ppm-poly--staff_only:hover { fill: rgba(100, 100, 100, 0.45); }
  .ppm-poly--maintenance { fill: rgba(180, 60, 60, 0.22); stroke: #b43c3c; stroke-dasharray: 6 3; }
  .ppm-poly--maintenance:hover { fill: rgba(180, 60, 60, 0.45); }
  .ppm-poly--reserved    { fill: rgba(80, 100, 160, 0.22); stroke: #5064a0; stroke-dasharray: 2 3; }
  .ppm-poly--reserved:hover { fill: rgba(80, 100, 160, 0.45); }
  .ppm-poly--seasonal_closed { fill: rgba(180, 180, 180, 0.25); stroke: #888; }
  .ppm-poly--seasonal_closed:hover { fill: rgba(180, 180, 180, 0.5); }

  .ppm-label {
    fill: #fff;
    font-family: var(--sans, system-ui);
    font-size: 16px;
    font-weight: 500;
    paint-order: stroke;
    stroke: rgba(0,0,0,0.55);
    stroke-width: 3;
    pointer-events: none;
  }

  .ppm-popover {
    position: absolute;
    min-width: 240px;
    max-width: 280px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.14);
    padding: 0.85rem 1rem;
    z-index: 40;
    pointer-events: auto;
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .ppm-popover[hidden] { display: none; }
  .ppm-pop-title {
    margin: 0 0 0.25rem;
    font-family: var(--serif, Georgia, serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--dark, #1E1008);
  }
  .ppm-pop-status {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.12rem 0.5rem;
    border-radius: 2px;
    margin-bottom: 0.5rem;
    background: rgba(74, 124, 89, 0.12);
    color: #3a6344;
  }
  .ppm-pop-status--camp_host       { background: rgba(212, 168, 83, 0.18); color: #7a5a14; }
  .ppm-pop-status--staff_only      { background: rgba(100, 100, 100, 0.15); color: #444; }
  .ppm-pop-status--maintenance     { background: rgba(180, 60, 60, 0.15); color: #8a2c2c; }
  .ppm-pop-status--reserved        { background: rgba(80, 100, 160, 0.15); color: #3d4c78; }
  .ppm-pop-status--seasonal_closed { background: rgba(120, 120, 120, 0.15); color: #555; }

  .ppm-pop-note {
    font-size: 0.8rem;
    color: var(--muted, #665040);
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .ppm-pop-note[hidden] { display: none; }

  .ppm-pop-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.65rem;
  }
  .ppm-chip {
    background: var(--sand, #f5efe3);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 999px;
    padding: 0.12rem 0.55rem;
    font-size: 0.72rem;
    color: var(--muted, #665040);
  }

  .ppm-pop-actions {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .ppm-pop-actions a {
    display: block;
    text-align: center;
    padding: 0.5rem 0.8rem;
    border-radius: 3px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }
  .ppm-pop-info {
    background: transparent;
    color: var(--rust, #C4622D);
    border: 1px solid var(--rust, #C4622D);
  }
  .ppm-pop-info:hover { background: var(--rust, #C4622D); color: #fff; }
  .ppm-pop-book {
    background: var(--rust, #C4622D);
    color: #fff;
  }
  .ppm-pop-book:hover { background: var(--rust-dark, #9A4A20); }
  .ppm-pop-book[hidden] { display: none; }
  .ppm-pop-call {
    background: #444;
    color: #fff;
  }
  .ppm-pop-call:hover { background: #222; }
  .ppm-pop-call[hidden] { display: none; }
</style>
