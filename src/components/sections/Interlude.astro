---
import { blockText, blockHtml, blockUrl, blockImage, blockBool, blockJson, type BlockMap } from '@lib/section-blocks';
export interface Props { blocks: BlockMap; }
const { blocks } = Astro.props;
const eyebrow = blockText(blocks, 'eyebrow', '');
const headline = blockHtml(blocks, 'headline', '');
const body = blockHtml(blocks, 'body', '');
const credit = blockText(blocks, 'credit', '');
const bg = blockImage(blocks, 'background_image', { url: '', alt: '' });
const ctaLabel = blockText(blocks, 'cta_label', '');
const ctaUrl = blockUrl(blocks, 'cta_url', '#');
const enableLightbox = blockBool(blocks, 'image_lightbox', false);
interface GalleryItem { image: string; alt?: string; }
const gallery = (blockJson<GalleryItem[]>(blocks, 'gallery', [])).filter((g) => g && g.image);
const hasGallery = gallery.length > 0;
// With photos attached, the photographs are the visual — paint a calm
// night-sky backdrop rather than a competing hero image, and never make
// the backdrop itself clickable.
const showBgImage = bg.url && !hasGallery;
const bgStyle = showBgImage
  ? `background-image:url('${bg.url}');`
  : 'background:linear-gradient(135deg,#0b1220 0%,#1b2340 45%,#242b4a 100%);';
const bgClickable = enableLightbox && showBgImage;
---
<section class={`interlude${hasGallery ? ' has-gallery' : ''}`}>
  <div
    class={`interlude-bg${bgClickable ? ' interlude-bg-clickable' : ''}`}
    style={bgStyle}
    data-lightbox={bgClickable ? 'true' : undefined}
    data-lightbox-src={bgClickable ? bg.url : undefined}
    data-lightbox-alt={bgClickable ? bg.alt : undefined}
    data-lightbox-caption={bgClickable ? credit : undefined}
    role={bgClickable ? 'button' : undefined}
    tabindex={bgClickable ? '0' : undefined}
    aria-label={bgClickable ? `View larger image${bg.alt ? `: ${bg.alt}` : ''}` : undefined}
  ></div>
  <div class="interlude-overlay"></div>
  <div class="interlude-content reveal">
    {eyebrow && <div class="interlude-eyebrow">{eyebrow}</div>}
    <h2 class="interlude-headline" set:html={headline}></h2>
    {body && <p class="interlude-body" set:html={body}></p>}
    {hasGallery && (
      <div class="interlude-gallery">
        {gallery.map((g) => (
          <figure>
            <img
              src={g.image}
              alt={g.alt ?? ''}
              loading="lazy"
              data-lightbox="true"
              data-lightbox-src={g.image}
              data-lightbox-alt={g.alt ?? ''}
              data-lightbox-caption={g.alt ?? credit}
            />
          </figure>
        ))}
      </div>
    )}
    {credit && <p class="interlude-credit">{credit}</p>}
    {ctaLabel && (
      <div class="section-cta section-cta-dark" style="margin-top:2rem;">
        <a href={ctaUrl} target={ctaUrl.startsWith('http') ? '_blank' : undefined} rel={ctaUrl.startsWith('http') ? 'noopener noreferrer' : undefined}>{ctaLabel}</a>
      </div>
    )}
  </div>
</section>
