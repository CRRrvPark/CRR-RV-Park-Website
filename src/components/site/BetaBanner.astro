---
/**
 * Sitewide opt-in to the Rimrock live-map beta.
 * Centered, mint/forest glass strip — matches V3 utility + section palette.
 */
---
<div class="crr-beta-banner" data-beta-banner>
  <div class="v2-shell crr-beta-banner-inner">
    <a class="crr-beta-banner-link" href="/availability">
      <span class="crr-beta-banner-label">Live map beta</span>
      <span class="crr-beta-banner-copy">
        Try our new live map — pick a site in Rimrock, then call to confirm and pay your deposit
      </span>
      <span class="crr-beta-banner-go" aria-hidden="true">Try it →</span>
    </a>
  </div>
</div>
