---
/**
 * Live Rimrock map mirror for the public beta path.
 * Embeds crr.stratapms.com in embed+request mode (exact RR map UI).
 * Guests use the normal Rimrock booking screens inside the iframe; RR emails
 * the park invisibly on submit. No website form on this page.
 * Optional: postMessage also lets this page silently POST to Netlify Forms.
 */

export interface Props {
  preferredType?: string;
}

const { preferredType = '' } = Astro.props;

const params = new URLSearchParams({ embed: '1', request: '1' });
if (preferredType) params.set('type', preferredType);
const RR_EMBED_URL = `https://crr.stratapms.com/?${params.toString()}`;
---
<div class="crr-rr-beta" data-rimrock-beta>
  <div class="v2-section-heading v2-reveal">
    <div>
      <p class="v2-eyebrow">Live map · beta</p>
      <h2>Use the map like a<br />normal booking.</h2>
    </div>
    <p>
      This is Rimrock’s live park map — a preview that may not be perfect.
      Search dates, pick a site, and enter your details inside the map.
      Submitting is <strong>not</strong> a confirmed reservation and does <strong>not</strong> take payment.
      After you submit, <strong>call <a href="tel:+15419231441">541-923-1441</a></strong> to confirm the site is still available and pay your deposit.
      Staff create the stay in Firefly from the request we receive.
    </p>
  </div>

  <div class="crr-live-panel crr-rr-embed-wrap v2-reveal">
    <iframe
      class="crr-rr-embed"
      src={RR_EMBED_URL}
      title="Crooked River Ranch — live Rimrock map (beta)"
      loading="eager"
      referrerpolicy="strict-origin-when-cross-origin"
      allow="fullscreen"
    ></iframe>
  </div>

  <p class="crr-rr-embed-note v2-reveal">
    Prefer a larger view?
    <a href={`https://crr.stratapms.com/?request=1${preferredType ? `&type=${encodeURIComponent(preferredType)}` : ''}`} target="_blank" rel="noopener">
      Open the live map in a new tab
    </a>
    · or book and pay now via
    <a href="https://app.fireflyreservations.com/reserve/property/CROOKEDRIVERRANCHRVPARK">Firefly</a>.
  </p>
</div>

{/* Invisible Netlify Forms bridge — kept off-screen; RR posts here when a request completes. */}
<form
  class="crr-beta-netlify-bridge"
  name="beta-reservation-request"
  method="POST"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  data-beta-netlify-bridge
  hidden
  aria-hidden="true"
  tabindex="-1"
>
  <input type="hidden" name="form-name" value="beta-reservation-request" />
  <input type="hidden" name="source_page" value="availability-beta" />
  <input type="text" name="bot-field" />
  <input type="text" name="first_name" data-nf-first />
  <input type="text" name="last_name" data-nf-last />
  <input type="email" name="email" data-nf-email />
  <input type="tel" name="phone" data-nf-phone />
  <input type="date" name="arrival" data-nf-arrival />
  <input type="date" name="departure" data-nf-departure />
  <input type="text" name="site_number" data-nf-site />
  <input type="text" name="site_type" data-nf-site-type />
  <input type="number" name="party_size" data-nf-party />
  <textarea name="notes" data-nf-notes></textarea>
  <input type="number" name="rig_length_ft" data-nf-rig />
  <input type="text" name="slides" data-nf-slides />
</form>

<script is:inline>
  (function () {
    var form = document.querySelector('[data-beta-netlify-bridge]');
    if (!form) return;

    function set(sel, value) {
      var el = form.querySelector(sel);
      if (!el || value == null) return;
      el.value = String(value);
    }

    function splitName(full) {
      var parts = String(full || '').trim().split(/\s+/);
      if (!parts.length || !parts[0]) return { first: '', last: '' };
      return { first: parts[0], last: parts.slice(1).join(' ') };
    }

    window.addEventListener('message', function (event) {
      if (event.origin !== 'https://crr.stratapms.com') return;
      var data = event.data;
      if (!data || data.type !== 'rimrock-beta-request') return;

      var names = splitName(data.guestName || data.name);
      set('[data-nf-first]', data.firstName || names.first);
      set('[data-nf-last]', data.lastName || names.last);
      set('[data-nf-email]', data.email);
      set('[data-nf-phone]', data.phone);
      set('[data-nf-arrival]', data.dateIn || data.arrival);
      set('[data-nf-departure]', data.dateOut || data.departure);
      set('[data-nf-site]', data.siteCode || data.site);
      set('[data-nf-site-type]', data.siteType || '');
      set('[data-nf-party]', data.partySize || data.party || '');
      set('[data-nf-notes]', data.notes || 'Submitted from Rimrock live map beta (invisible bridge).');
      set('[data-nf-rig]', data.rigLengthFt || '');
      set('[data-nf-slides]', data.slides || '');

      var body = new URLSearchParams(new FormData(form)).toString();
      fetch('/__forms.html', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body,
      }).catch(function () { /* RR email is the primary path */ });
    });
  })();
</script>
