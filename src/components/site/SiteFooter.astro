---
const year = new Date().getFullYear();
---
<footer class="crr-footer">
  <div class="v2-shell crr-footer-grid">
    <div class="crr-footer-lead">
      <a class="crr-brand crr-brand-footer" href="/">
        <span class="crr-brand-mark" aria-hidden="true">CR</span>
        <span>
          <strong>Crooked River Ranch</strong>
          <small>RV Park</small>
        </span>
      </a>
      <h2>Come for the canyon.<br />Arrive with a plan.</h2>
      <a class="v2-book-button" href="/availability">
        Find an open site <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="crr-footer-links">
      <div>
        <small>Stay</small>
        <a href="/sites">Sites &amp; site types</a>
        <a href="/availability">Live availability</a>
        <a href="/park-map">Park map</a>
        <a href="/group-sites">Group stays</a>
        <a href="/extended-stays">Extended stays</a>
        <a href="/golf-stays">Golf stays</a>
      </div>
      <div>
        <small>Park + area</small>
        <a href="/amenities">At the park</a>
        <a href="/area-guide">Area guide + map</a>
        <a href="/trails">Trails</a>
        <a href="/things-to-do">Things to do</a>
        <a href="/dining">Dining &amp; local</a>
        <a href="/events">Events</a>
      </div>
      <div>
        <small>Plan</small>
        <a href="/book-now">Plan your visit</a>
        <a href="/park-policies">Park policies</a>
        <a href="tel:+15419231441">541-923-1441</a>
        <a href="https://maps.google.com/?q=14875+SW+Hays+Lane+Terrebonne+OR+97760">Directions</a>
        <a href="https://app.fireflyreservations.com/GuestPortal/Property/CROOKEDRIVERRANCHRVPARK" target="_blank" rel="noreferrer">Manage a reservation ↗</a>
      </div>
    </div>

    <div class="crr-footer-bottom">
      <span>© {year} Crooked River Ranch RV Park</span>
      <span>14875 SW Hays Lane · Terrebonne, OR 97760</span>
      <span>Check-in 2:00 pm · Check-out 12:00 pm</span>
      <span><a href="/about-this-website">Application information</a> · <a href="/privacy">Privacy policy</a> · <a href="/terms">Website terms</a> · <a href="/sitemap.xml">Sitemap</a> · <a href="/admin/login" rel="nofollow">Staff</a></span>
    </div>

    <div class="crr-footer-app-disclosure">
      <strong>Crooked River Ranch RV Park Website</strong>
      <p>
        This is the park’s official guest-information website. It helps visitors explore RV sites,
        amenities, maps, local activities, live availability, and reservation options. The park’s
        authorized Google Business Profile connection is used to read public listing content,
        including customer photos and reviews, so that properly attributed guest experiences can
        appear on this website. <a href="/privacy">Read the privacy policy.</a>
      </p>
    </div>
  </div>
</footer>
