---
/**
 * Base — the shared layout wrapping every public page.
 *
 * Composes: HeadMeta + JSON-LD + Nav + <slot /> + Footer + Clarity
 *
 * Pass page-specific props (title, description, canonical, hero preload,
 * JSON-LD schema). The <slot /> receives the page's body content.
 *
 * Admin pages use a separate AdminBase layout (see /admin routes).
 */

import HeadMeta from '@components/HeadMeta.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
import JsonLd from '@components/JsonLd.astro';
import ClarityScript from '@components/ClarityScript.astro';
import ConversionTracker from '@components/ConversionTracker.astro';
import GoogleTagManager from '@components/GoogleTagManager.astro';
import Lightbox from '@components/Lightbox.astro';
import SeoBreadcrumbs from '@components/SeoBreadcrumbs.astro';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';
import {
  absoluteUrl,
  breadcrumbSchema,
  breadcrumbsForPath,
  canonicalUrl,
  webPageSchema,
  type BreadcrumbItem,
} from '@lib/seo';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogImageAlt?: string;
  heroImagePreload?: string;
  schemas?: Record<string, unknown>[];
  /** Set to true to suppress Microsoft Clarity on this page (rarely needed). */
  noAnalytics?: boolean;
  /** Set to 'noindex, nofollow' to keep this page out of search engines. */
  robots?: string;
  /** Optional override for the automatically generated public breadcrumb. */
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogImageAlt,
  heroImagePreload,
  schemas = [],
  noAnalytics = false,
  robots,
  breadcrumbs: breadcrumbOverride,
} = Astro.props;

const normalizedCanonical = canonicalUrl(canonical);
const normalizedOgImage = ogImage ? absoluteUrl(ogImage) : undefined;
const isIndexable = !robots?.toLowerCase().includes('noindex');
const breadcrumbs = isIndexable
  ? (breadcrumbOverride ?? breadcrumbsForPath(Astro.url.pathname, title))
  : [];
const generatedSchemas = isIndexable
  ? [
      webPageSchema(title, description, normalizedCanonical, normalizedOgImage),
      breadcrumbSchema(breadcrumbs, normalizedCanonical),
    ].filter((schema): schema is Record<string, unknown> => schema !== null)
  : [];
const allSchemas = [...generatedSchemas, ...schemas];
---
<!DOCTYPE html>
<html lang="en-US">
<head>
  <HeadMeta
    title={title}
    description={description}
    canonical={normalizedCanonical}
    ogImage={normalizedOgImage}
    ogImageAlt={ogImageAlt}
    heroImagePreload={heroImagePreload}
    robots={robots}
  />
  {allSchemas.length > 0 && <JsonLd schemas={allSchemas} />}
  {/* Google Tag Manager — loads as high in <head> as possible per Google's
     recommendation so early events fire with GTM already initialised.
     Gated by `noAnalytics` for parity with Clarity: admin pages pass
     `noAnalytics={true}` and neither tracker loads there. */}
  {!noAnalytics && <GoogleTagManager enabled={true} slot="script" />}
  {!noAnalytics && <ClarityScript />}
</head>
<body class="v2-page v3-page crr-site">
  {/* Google Tag Manager noscript fallback — must be the first element
     inside <body> per Google's install docs. */}
  {!noAnalytics && <GoogleTagManager enabled={true} slot="noscript" />}
  <!--
    Auth-hash fallback: if a user arrives on a public page with
    `#type=invite` or `#type=recovery` in the URL hash (e.g., they clicked
    a link whose `redirect_to` defaulted to Site URL instead of /admin/login —
    common when the link was generated from the Supabase dashboard), redirect
    to /admin/login so the LoginForm's set-password mode can consume the tokens.

    Runs inline before React or Supabase has a chance to touch the hash.
  -->
  <script is:inline>
    (function () {
      try {
        var hash = window.location.hash;
        if (!hash || hash.length < 2) return;
        var params = new URLSearchParams(hash.slice(1));
        var t = params.get('type');
        if (t !== 'invite' && t !== 'recovery') return;
        if (window.location.pathname.indexOf('/admin/login') === 0) return;
        window.location.replace('/admin/login' + hash);
      } catch (e) { /* no-op */ }
    })();
  </script>
  <a class="v2-skip-link" href="#main-content">Skip to content</a>
  <SiteHeader />
  <SeoBreadcrumbs items={breadcrumbs} />
  <slot />
  <SiteFooter />
  <a class="crr-mobile-book" href={FIREFLY_RESERVATION_URL} aria-hidden="true" tabindex="-1">
    <span>Book on Firefly</span>
    <span aria-hidden="true">↗</span>
  </a>
  <Lightbox />
  {!noAnalytics && <ConversionTracker />}
  <script src="/scripts/production-v3.js?v=20260719d" is:inline defer></script>
</body>
</html>
