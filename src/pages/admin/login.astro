---
/**
 * /admin/login — no layout chrome, just a centered auth card.
 *
 * prerender is explicitly false because the Supabase client needs to
 * hydrate with the browser's cookies before redirecting to /admin.
 */
export const prerender = false;

import HeadMeta from '@components/HeadMeta.astro';
import { LoginForm } from '@components/react/LoginForm.tsx';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <HeadMeta
    title="Sign in · CRR Admin"
    description="Crooked River Ranch admin login"
    canonical="https://www.crookedriverranchrv.com/admin/login"
    robots="noindex, nofollow"
  />
  <link rel="stylesheet" href="/styles/admin.css">
  <style>
    body.login-body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--font-sans);
      color: var(--c-text);
      background:
        radial-gradient(1200px 600px at 10% -10%, rgba(212, 168, 83, 0.12), transparent 60%),
        radial-gradient(900px 500px at 110% 110%, rgba(196, 98, 45, 0.12), transparent 60%),
        linear-gradient(180deg, #1a120a 0%, #2c1810 100%);
      display: grid;
      grid-template-columns: 1fr;
      align-items: center;
      justify-items: center;
      padding: var(--sp-6);
    }
    @media (min-width: 900px) {
      body.login-body {
        grid-template-columns: 1fr 480px;
        gap: var(--sp-10);
        padding: var(--sp-10);
        justify-items: stretch;
      }
    }
    .login-brand {
      color: #fff;
      padding: var(--sp-8);
      max-width: 520px;
      margin-left: auto;
    }
    .login-brand-mark {
      width: 60px; height: 60px; border-radius: var(--r-lg);
      background: linear-gradient(135deg, var(--c-rust), var(--c-gold));
      display: grid; place-items: center;
      font-family: var(--font-serif); color: #1B1209; font-weight: 500; font-size: 1.6rem;
      margin-bottom: var(--sp-6);
    }
    .login-brand h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      font-weight: 300;
      line-height: 1.08;
      color: #fff;
      margin: 0 0 var(--sp-4);
      letter-spacing: -0.005em;
    }
    .login-brand h1 em { color: var(--c-gold); font-style: italic; }
    .login-brand p {
      color: rgba(255,255,255,.72);
      font-size: 1.05rem;
      line-height: 1.7;
      max-width: 440px;
    }
    .login-brand ul {
      list-style: none; padding: 0; margin-top: var(--sp-6);
      display: grid; gap: var(--sp-3);
      color: rgba(255,255,255,.72);
      font-size: 0.95rem;
    }
    .login-brand li {
      display: flex; gap: var(--sp-3); align-items: flex-start;
      line-height: 1.55;
    }
    .login-brand li::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--c-gold); margin-top: 9px; flex-shrink: 0;
    }
    @media (max-width: 899px) {
      .login-brand { display: none; }
    }
    .login-card {
      background: var(--c-surface);
      padding: var(--sp-10) var(--sp-8);
      border-radius: var(--r-xl);
      width: 100%;
      max-width: 420px;
      box-shadow: 0 40px 80px -20px rgba(0,0,0,.5), 0 10px 25px -10px rgba(0,0,0,.35);
      margin-right: auto;
    }
    .login-header {
      margin-bottom: var(--sp-6);
    }
    .login-header .eyebrow {
      font-size: var(--fs-xs); letter-spacing: .18em; text-transform: uppercase;
      color: var(--c-rust); font-weight: 500;
      margin-bottom: var(--sp-2);
    }
    .login-header h2 {
      font-family: var(--font-serif);
      font-size: 1.8rem; font-weight: 400;
      margin: 0;
      color: var(--c-text);
    }
    .login-header p {
      color: var(--c-text-muted);
      font-size: var(--fs-md);
      margin-top: var(--sp-2);
      line-height: 1.55;
    }
    .login-footer {
      margin-top: var(--sp-6);
      padding-top: var(--sp-4);
      border-top: 1px solid var(--c-border);
      font-size: var(--fs-sm);
      color: var(--c-text-muted);
      text-align: center;
      line-height: 1.6;
    }
    .login-footer a { color: var(--c-rust); }
  </style>
</head>
<body class="login-body">
  <div class="login-brand">
    <div class="login-brand-mark">CR</div>
    <h1>Tend the <em>site.</em></h1>
    <p>
      This console lets you update everything on crookedriverranchrv.com —
      prices, amenities, events, and photos — without touching code.
    </p>
    <ul>
      <li>Every change is versioned. Roll back any publish in seconds.</li>
      <li>Your edits preview before they go live.</li>
      <li>Invite editors with just-enough access; own the decisions yourself.</li>
    </ul>
  </div>

  <div class="login-card">
    <div class="login-header">
      <div class="eyebrow">Admin Console</div>
      <h2>Welcome back</h2>
      <p>Sign in with the email you were invited with.</p>
    </div>
    <LoginForm client:load />
    <div class="login-footer">
      Need help? Email <a href="mailto:rvpark@crookedriverranch.com">rvpark@crookedriverranch.com</a>
    </div>
  </div>
</body>
</html>
