---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import RimrockBetaMap from '@components/site/RimrockBetaMap.astro';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';

const preferredType = Astro.url.searchParams.get('type') ?? '';

const title = 'Live Map Beta — Request a Site | Crooked River Ranch RV Park';
const description =
  'Try the Rimrock live map beta: preview open sites, send a request to the park, then call 541-923-1441 to confirm and pay your deposit. Not a confirmed reservation.';
const canonical = 'https://www.crookedriverranchrv.com/availability';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/aerial_wide.jpg" heroImagePreload="/images/aerial_wide.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Live map · beta"
      headline="Request a site"
      accent="on the Rimrock map."
      body="This is Rimrock’s live park map — a preview, not a confirmed booking. Pick a site, send your details, then call 541-923-1441 to confirm availability and pay your deposit. Staff create the stay in Firefly after that call."
      image="/images/aerial_wide.webp"
      imageMobile="/images/aerial_wide-mobile.webp"
      imageJpg="/images/aerial_wide.jpg"
      alt="Aerial view of Crooked River Ranch RV Park and the surrounding canyon"
      caption="Rimrock live map · request path · call required"
      primaryHref="#live-availability"
      primaryLabel="Open live map (beta)"
      secondaryHref="tel:+15419231441"
      secondaryLabel="Call 541-923-1441"
    />
    <section class="crr-section crr-section-soft" id="live-availability">
      <div class="v2-shell">
        <RimrockBetaMap preferredType={preferredType} />
      </div>
    </section>
    <FinalCta
      headline="Prefer to book and pay online now?"
      body="Use the normal reservation path for live availability, payment, and confirmation — or call 541-923-1441."
      image="/images/canyon_sunset.webp"
      primaryHref={FIREFLY_RESERVATION_URL}
      primaryLabel="Book your site"
      secondaryHref="tel:+15419231441"
      secondaryLabel="Call 541-923-1441"
    />
  </main>
</Base>
