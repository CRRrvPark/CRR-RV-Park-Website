---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import AvailabilityMap from '@components/AvailabilityMap.astro';
import { getParkSites } from '@lib/area-guide';
import { serverClient } from '@lib/supabase';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';

const sites = await getParkSites();
let activeParkMap: { image_url: string; title: string; natural_width: number; natural_height: number } | null = null;
try {
  const { data } = await serverClient()
    .from('park_maps')
    .select('image_url, title, natural_width, natural_height')
    .eq('is_active', true)
    .order('priority', { ascending: false })
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (data) activeParkMap = data as NonNullable<typeof activeParkMap>;
} catch {}

const polygonSites = sites.filter((site) => Array.isArray(site.map_polygon) && site.map_polygon.length > 0 && site.is_published !== false);
const title = 'Live RV Site Availability | Crooked River Ranch RV Park';
const description = 'Enter your dates, rig length, slide configuration, and hookup preference to see compatible open sites at Crooked River Ranch RV Park.';
const canonical = 'https://www.crookedriverranchrv.com/availability';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/aerial_wide.jpg" heroImagePreload="/images/aerial_wide.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Live availability"
      headline="See what is open."
      accent="See what fits."
      body="Enter the exact trip and rig details once. Compatible open sites appear on the park map with a direct reservation handoff."
      image="/images/aerial_wide.webp"
      imageMobile="/images/aerial_wide-mobile.webp"
      imageJpg="/images/aerial_wide.jpg"
      alt="Aerial view of Crooked River Ranch RV Park and the surrounding canyon"
      caption="Live site search on the full park layout"
      primaryHref="#live-availability"
      primaryLabel="Try the live map beta"
      secondaryHref={FIREFLY_RESERVATION_URL}
      secondaryLabel="Book directly on Firefly"
    />
    <section class="crr-section crr-section-soft" id="live-availability">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div><p class="v2-eyebrow">Your dates + your rig</p><h2>Compatible sites<br />on the map.</h2></div>
          <p>Green sites match the current search. Open a site for details, then continue to Firefly for payment and confirmation.</p>
        </div>
        <div class="crr-live-panel v2-reveal">
          {activeParkMap && polygonSites.length ? (
            <AvailabilityMap parkMap={activeParkMap} sites={polygonSites as any} />
          ) : (
            <div class="crr-empty-state"><h3>Call for current availability.</h3><p>The live map is temporarily unavailable. Have your dates, exact rig length, and slides ready, then call <a href="tel:+15419231441">541-923-1441</a>.</p></div>
          )}
        </div>
      </div>
    </section>
    <FinalCta headline="Ready to complete the reservation?" body="Firefly holds the authoritative inventory and completes payment and confirmation. The office can help when fit is uncertain." image="/images/canyon_sunset.webp" primaryHref={FIREFLY_RESERVATION_URL} primaryLabel="Book now on Firefly" secondaryHref="tel:+15419231441" secondaryLabel="Call 541-923-1441" />
  </main>
</Base>
