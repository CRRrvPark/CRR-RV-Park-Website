---
export const prerender = false;

import Base from '@layouts/Base.astro';
import AvailabilityMap from '@components/AvailabilityMap.astro';
import PageHero from '@components/site/PageHero.astro';
import { getParkSites } from '@lib/area-guide';
import { serverClient } from '@lib/supabase';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';
import FinalCta from '@components/site/FinalCta.astro';

const sites = await getParkSites();
let activeParkMap:
  | { image_url: string; title: string; natural_width: number; natural_height: number }
  | null = null;

try {
  const sb = serverClient();
  const { data } = await sb
    .from('park_maps')
    .select('image_url, title, natural_width, natural_height')
    .eq('is_active', true)
    .order('priority', { ascending: false })
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (data) activeParkMap = data as unknown as typeof activeParkMap;
} catch {
  // The Firefly and phone paths below remain available when the map cannot load.
}

const polygonSites = sites.filter(
  (site) => Array.isArray(site.map_polygon) && (site.map_polygon as unknown[]).length > 0 && site.is_published !== false,
);
const canRenderMap = Boolean(activeParkMap) && polygonSites.length > 0;

const title = 'Rates, Arrival & Reservations | Crooked River Ranch RV Park';
const description = 'Current starting rates, check-in times, and how to reserve an RV site at Crooked River Ranch near Smith Rock. Book online or call the office.';
const canonical = 'https://www.crookedriverranchrv.com/book-now';

const bookingFaqs = [
  {
    question: 'Do I book on this website?',
    answer: 'You’ll start here and finish in our reservation system (Firefly) for payment and confirmation.',
  },
  {
    question: 'Is there a reservation fee?',
    answer: 'Yes — $6, plus tax on rates.',
  },
  {
    question: 'What’s the monthly rate?',
    answer: '$850 for full hookup, October–April, application required.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: bookingFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage="https://www.crookedriverranchrv.com/images/winter_sunset.jpg"
  heroImagePreload="/images/winter_sunset.webp"
  schemas={[faqSchema]}
>
  <main id="main-content">
    <PageHero
      eyebrow="Plan your visit"
      headline="Rates, arrival details,"
      accent="and how to book."
      body="Reserve online for live availability, payment, and confirmation. Optional: preview sites on the live map first. Or call 541-923-1441."
      image="/images/winter_sunset.webp"
      imageMobile="/images/winter_sunset-mobile.webp"
      imageJpg="/images/winter_sunset.jpg"
      alt="Winter sunset over the Crooked River canyon"
      caption="Open year-round · Seasonal amenities vary"
      primaryHref={FIREFLY_RESERVATION_URL}
      primaryLabel="Book your site"
      secondaryHref="#live-availability"
      secondaryLabel="Live map (beta)"
    />

    <section class="v2-live-section" id="live-availability">
      <div class="v2-shell">
        <div class="v2-live-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Optional planning preview</p>
            <h2>Optional: preview<br />on the live map</h2>
          </div>
          <p>Enter dates and rig details to look around. When you’re ready to pay and confirm, book online.</p>
        </div>
        <div class="v2-live-map v2-reveal">
          {canRenderMap && activeParkMap ? (
            <AvailabilityMap parkMap={activeParkMap} sites={polygonSites as any} />
          ) : (
            <div class="v2-live-fallback">
              <p class="v2-eyebrow">We can still help</p>
              <h3>Call for current availability.</h3>
              <p>Have your dates, rig type, exact length, and slide configuration ready.</p>
              <div>
                <a class="v2-button v2-button-blue" href="tel:+15419231441">Call 541-923-1441 <span aria-hidden="true">→</span></a>
                <a class="v2-inline-link" href={FIREFLY_RESERVATION_URL} target="_blank" rel="noreferrer">Book online <span aria-hidden="true">↗</span></a>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="v2-booking-sequence">
      <div class="v2-shell">
        <div class="v2-sequence-heading v2-reveal">
          <p class="v2-eyebrow v2-eyebrow-light">How booking works</p>
          <h2>How booking works</h2>
        </div>
        <ol class="v2-sequence-grid">
          <li class="v2-reveal"><span>01</span><h3>Open the reservation page.</h3><p>Choose your arrival and departure dates online.</p></li>
          <li class="v2-reveal"><span>02</span><h3>Pick an available site.</h3><p>Review the current choices for your dates and select the one that works.</p></li>
          <li class="v2-reveal"><span>03</span><h3>Pay and receive confirmation.</h3><p>You’ll finish payment and confirmation in Firefly.</p></li>
        </ol>
      </div>
    </section>

    <section class="crr-section crr-section-dark" id="rates">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Rates at a glance</p>
            <h2>Current starting<br />rates</h2>
          </div>
          <p>Taxes and the reservation fee are added when you book. Review the final total and cancellation terms before confirming.</p>
        </div>
        <div class="crr-table-wrap v2-reveal">
          <table class="crr-table">
            <thead><tr><th>Site type</th><th>Nightly</th><th>Weekly</th><th>Monthly</th><th>Notes</th></tr></thead>
            <tbody>
              <tr><th>Full hookup</th><td>$62</td><td>$372</td><td>$850</td><td>Monthly October–April</td></tr>
              <tr><th>Water + electric</th><td>$57</td><td>$342</td><td>—</td><td>30/50 amp options</td></tr>
              <tr><th>Tent / dry camp</th><td>$36</td><td>—</td><td>—</td><td>No hookups</td></tr>
              <tr><th>EV charging</th><td>+$15</td><td>+$15/night</td><td>Call</td><td>Bring the appropriate adapter</td></tr>
            </tbody>
          </table>
        </div>
        <p class="crr-rate-note v2-reveal">Monthly rates are available October 1–April 30. Rates exclude tax. A $6 reservation fee applies per booking. Good Sam, military/first responder, and Harvest Hosts members receive 10% off eligible nightly rates; verify the discount with the office.</p>
      </div>
    </section>

    <section class="crr-section">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Before the drive</p>
            <h2>Arrival basics</h2>
          </div>
          <p>14875 SW Hays Lane, Terrebonne, OR 97760. Check-in 2:00 pm · Check-out 12:00 pm. Open year-round; the pool and some recreation are seasonal. Pets are welcome.</p>
        </div>
        <div class="v2-arrival-grid">
          <article class="v2-arrival-primary v2-reveal">
            <span>Arrival</span>
            <h3>14875 SW Hays Lane<br />Terrebonne, OR 97760</h3>
            <a href="https://maps.google.com/?q=14875+SW+Hays+Lane+Terrebonne+OR+97760">Open directions ↗</a>
          </article>
          <article class="v2-arrival-card v2-reveal"><span>Check-in</span><strong>2:00 pm</strong><p>Call ahead to ask about early arrival.</p></article>
          <article class="v2-arrival-card v2-reveal"><span>Check-out</span><strong>12:00 pm</strong><p>Plan departure around the noon checkout.</p></article>
          <article class="v2-arrival-card v2-reveal"><span>Pets</span><strong>Welcome</strong><p>Off-leash dog run; leashes apply elsewhere.</p></article>
          <article class="v2-arrival-card v2-reveal"><span>Season</span><strong>Open year-round</strong><p>The heated pool and select amenities are seasonal.</p></article>
        </div>
      </div>
    </section>

    <section class="v2-policy-band">
      <div class="v2-shell v2-policy-grid">
        <div class="v2-reveal">
          <p class="v2-eyebrow">Current terms</p>
          <h2>Read the policies<br />before you book</h2>
          <p>Quiet hours, propane-only fires, pet rules, and cancellation terms — better now than at the gate.</p>
        </div>
        <div class="v2-policy-actions v2-reveal">
          <a class="v2-policy-link" href="/park-policies"><span>Read park policies</span><i>→</i></a>
          <a class="v2-policy-link" href="https://app.fireflyreservations.com/GuestPortal/Property/CROOKEDRIVERRANCHRVPARK" target="_blank" rel="noreferrer"><span>Manage a reservation</span><i>↗</i></a>
          <a class="v2-policy-link" href="tel:+15419231441"><span>Call 541-923-1441</span><i>→</i></a>
        </div>
      </div>
    </section>

    <section class="v2-help-strip">
      <div class="v2-shell v2-help-strip-grid">
        <div class="v2-reveal">
          <p class="v2-eyebrow v2-eyebrow-light">Need a hand?</p>
          <h2>Need help choosing a site?</h2>
        </div>
        <div class="v2-help-actions v2-reveal">
          <p>Tell us your rig length, slides, and what you care about (canyon, shade, near the pool). We’ll help.</p>
          <a class="v2-button v2-button-yellow" href="tel:+15419231441">Call the park <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section class="crr-section crr-section-soft" id="booking-faq">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Common questions</p>
            <h2>Booking FAQ</h2>
          </div>
        </div>
        <div class="crr-faq-list v2-reveal">
          {bookingFaqs.map((faq) => (
            <details class="crr-faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <FinalCta
      headline="Book your site."
      body="Check dates, pay, and get confirmation online."
      primaryHref={FIREFLY_RESERVATION_URL}
      primaryLabel="Book your site"
      secondaryHref="#live-availability"
      secondaryLabel="Live map (beta)"
    />
  </main>
</Base>
