---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';
import LocalPlaceCard from '@components/LocalPlaceCard.astro';
import { getLocalPlaces } from '@lib/area-guide';

const places = await getLocalPlaces();
const groups = [
  { key: 'restaurant', label: 'Restaurants', heading: 'Sit-down and easy nights out.' },
  { key: 'brewery', label: 'Breweries', heading: 'A local pour.' },
  { key: 'coffee', label: 'Coffee', heading: 'Coffee to start the day.' },
  { key: 'shop', label: 'Local shops', heading: 'Useful stops.' },
  { key: 'attraction', label: 'Attractions', heading: 'Worth a short drive.' },
  { key: 'other', label: 'More nearby', heading: 'More nearby.' },
] as const;
const placeCardHelper = 'Open a card for directions, the official website, current rating context, and availability details when supplied by Google.';
const title = 'Dining, Coffee & Local Favorites near Crooked River Ranch';
const description = 'Browse nearby restaurants, breweries, coffee, shops, and local favorites with current Google details and directions from Crooked River Ranch RV Park.';
const canonical = 'https://www.crookedriverranchrv.com/dining';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/central_oregon.jpg" heroImagePreload="/images/central_oregon.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Food & local stops"
      headline="Where to eat"
      accent="near the Ranch."
      body="Restaurants, coffee, local pours, and useful stops — with current details from Google."
      image="/images/central_oregon.webp"
      imageMobile="/images/central_oregon-mobile.webp"
      imageJpg="/images/central_oregon.jpg"
      alt="Central Oregon town and local storefronts"
      caption="Live details and directions from Google"
      primaryHref="#local-places"
      primaryLabel="Browse local places"
      secondaryHref="/area-guide#area-map"
      secondaryLabel="Open the area map"
    />

    <section class="crr-section crr-section-soft" id="local-places">
      <div class="v2-shell">
        {!places.length ? (
          <div class="crr-empty-state"><h3>The local guide is refreshing.</h3><p>Open the <a href="/area-guide#area-map">area map</a> or ask the office for a nearby recommendation.</p></div>
        ) : (
          <>
            <p class="crr-data-note v2-reveal" style="margin-bottom: 1.5rem;">{placeCardHelper}</p>
            {groups.map((group) => {
              const matches = places.filter((place) => place.category === group.key);
              return matches.length ? (
                <section class="crr-list-section">
                  <div class="v2-section-heading v2-reveal">
                    <div><p class="v2-eyebrow">{group.label}</p><h2>{group.heading}</h2></div>
                  </div>
                  <div class="crr-card-grid">{matches.map((place) => <LocalPlaceCard place={place} />)}</div>
                </section>
              ) : null;
            })}
          </>
        )}
        <p class="crr-data-note">Place details are supplied by Google and may change. Confirm hours and availability with the business before driving.</p>
      </div>
    </section>

    <FinalCta headline="Bring dinner back to camp." body="Grab something nearby and finish the evening on the canyon." image="/images/firepit_evening.webp" primaryHref={FIREFLY_RESERVATION_URL} primaryLabel="Book your site" secondaryHref="/area-guide" secondaryLabel="Plan the full day" />
  </main>
</Base>
