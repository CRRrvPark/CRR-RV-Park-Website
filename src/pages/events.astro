---
export const prerender = true;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import rrulePkg from 'rrule';

const { RRule, rrulestr } = rrulePkg as any;
type RRuleType = InstanceType<typeof RRule>;
type EventRow = { id: string; title: string; description: string | null; location: string | null; starts_at: string; ends_at: string; is_all_day: boolean; recurrence_rule: string | null };
type Instance = { key: string; title: string; description: string | null; location: string | null; starts_at: string; ends_at: string; is_all_day: boolean; is_recurring: boolean };

const now = new Date();
const windowEnd = new Date(now);
windowEnd.setFullYear(windowEnd.getFullYear() + 1);
let instances: Instance[] = [];

try {
  if (import.meta.env.PUBLIC_SUPABASE_URL) {
    const { serverClient } = await import('../lib/supabase');
    const { data, error } = await serverClient()
      .from('events')
      .select('id,title,description,location,starts_at,ends_at,is_all_day,recurrence_rule')
      .eq('is_published', true)
      .or(`ends_at.gte.${now.toISOString()},recurrence_rule.not.is.null`);
    if (error) throw error;
    for (const row of (data ?? []) as EventRow[]) {
      const startAnchor = new Date(row.starts_at);
      const endAnchor = new Date(row.ends_at);
      const durationMs = Math.max(0, endAnchor.getTime() - startAnchor.getTime());
      const rule = (row.recurrence_rule ?? '').trim().replace(/^RRULE:/i, '');
      if (rule) {
        try {
          const recurrence: RRuleType = rrulestr(rule, { dtstart: startAnchor });
          for (const start of recurrence.between(now, windowEnd, true)) {
            instances.push({ key: `${row.id}#${start.toISOString()}`, title: row.title, description: row.description, location: row.location, starts_at: start.toISOString(), ends_at: new Date(start.getTime() + durationMs).toISOString(), is_all_day: row.is_all_day, is_recurring: true });
          }
        } catch {
          if (endAnchor >= now) instances.push({ ...row, key: row.id, is_recurring: false });
        }
      } else if (endAnchor >= now) {
        instances.push({ ...row, key: row.id, is_recurring: false });
      }
    }
    instances.sort((a, b) => a.starts_at.localeCompare(b.starts_at));
  }
} catch (error) {
  console.warn('[events.astro] Could not fetch events:', error);
}

const fmtDate = (iso: string, allDay: boolean) => new Date(iso).toLocaleDateString('en-US', allDay
  ? { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric' }
  : { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
const fmtEndTime = (iso: string) => new Date(iso).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
const title = 'Upcoming Events | Crooked River Ranch RV Park';
const description = 'See published park gatherings and seasonal events at Crooked River Ranch RV Park, with flexible date filtering.';
const canonical = 'https://www.crookedriverranchrv.com/events';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/gazebo_fall.jpg" heroImagePreload="/images/gazebo_fall.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Events"
      headline="What’s on"
      accent="the calendar."
      body="Park gatherings and seasonal events appear here after they’re published."
      image="/images/gazebo_fall.webp"
      imageMobile="/images/gazebo_fall-mobile.webp"
      imageJpg="/images/gazebo_fall.jpg"
      alt="Gazebo and autumn trees at Crooked River Ranch"
      caption="Calendar updates sync from Zoho"
      primaryHref="#event-list"
      primaryLabel="See upcoming events"
      secondaryHref="/group-sites"
      secondaryLabel="Plan a group stay"
    />

    <section class="crr-section crr-section-soft" id="event-list">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal"><div><p class="v2-eyebrow">Upcoming</p><h2>Pick a date.<br />See the details.</h2></div><p>Use a quick range or enter exact dates. Published calendar changes appear within the normal sync window.</p></div>
        {instances.length > 0 && (
          <div class="crr-event-filter v2-reveal">
            <div class="crr-filter-row">
              <button type="button" class="events-chip" data-range="week" aria-pressed="false">This week</button>
              <button type="button" class="events-chip" data-range="month" aria-pressed="false">This month</button>
              <button type="button" class="events-chip" data-range="quarter" aria-pressed="false">Next 3 months</button>
              <button type="button" class="events-chip" data-range="all" aria-pressed="true">All upcoming</button>
            </div>
            <div class="crr-event-dates">
              <label>From<input type="date" id="events-from" /></label>
              <label>To<input type="date" id="events-to" /></label>
              <button type="button" id="events-clear">Clear dates</button>
            </div>
          </div>
        )}

        {!instances.length ? (
          <div class="crr-empty-state v2-reveal"><h3>No published events are on the calendar yet.</h3><p>Check back soon or call <a href="tel:+15419231441">541-923-1441</a> with a group-stay question.</p></div>
        ) : (
          <>
            <div class="crr-event-grid" id="events-list">
              {instances.map((event) => (
                <article class="crr-detail-card events-card v2-reveal" data-event-start={event.starts_at}>
                  <small>{fmtDate(event.starts_at, event.is_all_day)}{!event.is_all_day && ` – ${fmtEndTime(event.ends_at)}`}</small>
                  <h3>{event.title}</h3>
                  {event.location && <p><strong>Location:</strong> {event.location}</p>}
                  {event.description && <p>{event.description}</p>}
                  {event.is_recurring && <span class="crr-event-recurring">Recurring event</span>}
                </article>
              ))}
            </div>
            <div id="events-empty-filtered" class="crr-empty-state" hidden><h3>No events fall inside those dates.</h3><p>Widen the range or clear the date fields.</p></div>
          </>
        )}
        <p class="crr-data-note">Calendar content is synced from Zoho Calendar, normally within one hour of a published change.</p>
      </div>
    </section>
    <FinalCta headline="Staying for an event?" body="Book a site for those dates, or call if several rigs need to stay close together." image="/images/family_reunion.webp" />
  </main>
  <script is:inline>
    (() => {
      const cards = document.querySelectorAll('.events-card');
      const from = document.getElementById('events-from');
      const to = document.getElementById('events-to');
      const chips = document.querySelectorAll('.events-chip');
      const clear = document.getElementById('events-clear');
      const empty = document.getElementById('events-empty-filtered');
      if (!cards.length || !from || !to) return;
      const ymd = (date) => `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
      const apply = () => {
        const first = from.value ? new Date(`${from.value}T00:00:00`).getTime() : -Infinity;
        const last = to.value ? new Date(`${to.value}T23:59:59.999`).getTime() : Infinity;
        let shown = 0;
        cards.forEach((card) => {
          const match = new Date(card.dataset.eventStart).getTime() >= first && new Date(card.dataset.eventStart).getTime() <= last;
          card.hidden = !match;
          if (match) shown += 1;
        });
        if (empty) empty.hidden = shown !== 0;
      };
      const activate = (selected) => chips.forEach((chip) => chip.setAttribute('aria-pressed', chip === selected ? 'true' : 'false'));
      chips.forEach((chip) => chip.addEventListener('click', () => {
        const start = new Date();
        let end = new Date(start);
        if (chip.dataset.range === 'week') end.setDate(end.getDate() + 7);
        else if (chip.dataset.range === 'month') end.setMonth(end.getMonth() + 1);
        else if (chip.dataset.range === 'quarter') end.setMonth(end.getMonth() + 3);
        else { from.value = ''; to.value = ''; activate(chip); apply(); return; }
        from.value = ymd(start); to.value = ymd(end); activate(chip); apply();
      }));
      [from, to].forEach((input) => input.addEventListener('change', () => { activate(null); apply(); }));
      clear?.addEventListener('click', () => { from.value = ''; to.value = ''; activate(document.querySelector('[data-range="all"]')); apply(); });
    })();
  </script>
</Base>
