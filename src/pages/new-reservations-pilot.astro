---
/**
 * /new-reservations-pilot — the RR-GATED pilot page for the new reservation
 * system (re-ported 2026-07-22 from the pre-V3 `feat/rr-pilot-gate` branch;
 * re-skinned onto the V3 design system same night — the first deploy shipped
 * with the retired pre-V3 classes and rendered off-theme).
 *
 * THE GATE IS RIMROCK'S, NOT THE PAGE'S: on load the page asks the same-origin
 * proxy `/api/pilot-status` (→ crr.stratapms.com/api/public/pilot-status) and
 *   • CLOSED (or unreachable, or JS off) → a polite "currently closed" notice
 *     with the open schedule. FAIL-CLOSED by construction: the closed notice is
 *     the server-rendered default and only an explicit `ok && open` reveals
 *     the pilot. The owner opens/closes it from Rimrock (the `pilot_portal`
 *     setting — Admin → Settings → Guest portal); no site deploy needed.
 *   • OPEN → the disclaimer interstitial:
 *     (a) no credit card / payment info is captured in the trial,
 *     (b) availability is accurate within a reasonable margin,
 *     (c) real reservations are confirmed by the park office directly,
 *     (d) feedback earns a $10 credit toward a future stay of 2+ nights —
 *     then the click-through CTA to the live guest portal.
 *
 * Unlinked (not in Nav) + noindex: reachable by direct URL, handed out by the
 * park during open hours.
 */
export const prerender = true;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';

const PILOT_URL = 'https://crr.stratapms.com/'; // the live guest portal (StrataPMS door)
// The pilot embeds the real booking widget in PILOT mode: full flow (live map,
// search, pick a site, reserve) with the deposit auto-recorded as a test — the
// guest enters no card. `embed=1` drops the widget's own header/hero; `pilot=1`
// turns on the sandbox auto-charge (the RR server honors it only in sandbox).
const PILOT_EMBED_URL = 'https://crr.stratapms.com/?embed=1&pilot=1';

const title = 'Try Our New Reservation System | Crooked River Ranch RV Park';
const description = 'Help us test a more modern, more intuitive way to reserve your site at Crooked River Ranch RV Park — and earn a $10 credit toward a future stay for your feedback.';
const canonical = 'https://www.crookedriverranchrv.com/new-reservations-pilot';
---
<Base title={title} description={description} canonical={canonical} robots="noindex, nofollow" heroImagePreload="/images/aerial_wide.webp">
  <main id="main-content">
    <PageHero
      eyebrow="You're invited"
      headline="Try our new"
      accent="reservation system."
      body="We are currently exploring an alternative, more modern, and more intuitive way to book your stay — and we would love your feedback."
      image="/images/aerial_wide.webp"
      imageMobile="/images/aerial_wide-mobile.webp"
      imageJpg="/images/aerial_wide.jpg"
      alt="Aerial view of Crooked River Ranch RV Park and the surrounding canyon"
      caption="The park you're booking — from above"
      primaryHref="#pilot"
      primaryLabel="Start the pilot"
      secondaryHref="/availability"
      secondaryLabel="Live map (beta)"
    />

    <section class="crr-section crr-section-soft" id="pilot">
      <div class="v2-shell">

        <!-- CLOSED is the DEFAULT (fail-closed): shown until the live gate says open -->
        <div id="pilot-closed">
          <div class="v2-section-heading v2-reveal">
            <div>
              <p class="v2-eyebrow">The pilot</p>
              <h2>The test window is<br />currently closed.</h2>
            </div>
            <p>
              The new reservation system opens for guest testing during office hours so
              our staff can follow up with you personally.
            </p>
          </div>
          <div class="crr-live-panel v2-reveal">
            <div class="crr-empty-state">
              <h3>Check back <span id="pilot-schedule">Monday–Saturday, 10:00 AM–3:00 PM Pacific</span>.</h3>
              <p>
                Or call the office at <a href="tel:+15419231441">541-923-1441</a> and
                we'll be happy to help with your reservation right now. You can browse
                <a href="/availability">live map beta</a> any time.
              </p>
            </div>
          </div>
        </div>

        <!-- OPEN content: revealed ONLY when Rimrock's gate answers ok && open -->
        <div id="pilot-open" hidden>
          <div class="v2-section-heading v2-reveal">
            <div>
              <p class="v2-eyebrow">The pilot</p>
              <h2>A better way<br />to book.</h2>
            </div>
            <p>
              Browse real availability on the live map, pick your site, and complete a
              reservation right here — no card needed for the pilot. Then tell us what you
              loved, what confused you, and what you'd change. Prefer a quick look first? The
              <a href="/availability">live map beta</a> is a separate request path
              (call required — not this pilot).
            </p>
          </div>

          <div class="crr-live-panel v2-reveal pilot-gate" id="pilot-gate">
            <p class="v2-eyebrow">Before you begin — please read</p>
            <ul class="pilot-terms">
              <li>
                <strong>No card needed — you enter no payment details.</strong> For this
                pilot the deposit is handled automatically as a test, so you can try the
                whole flow without a real charge.
              </li>
              <li>
                <strong>Availability is close, not guaranteed.</strong> The site
                availability shown is accurate within a reasonable margin, but it isn't
                the park's final word.
              </li>
              <li>
                <strong>We confirm with you, personally.</strong> Your reservation is
                recorded in our new system and we follow up from the park office to
                finalize your site — this pilot never replaces that call.
              </li>
              <li>
                <strong>Your feedback earns you $10.</strong> Share your feedback on the
                new system and we'll credit <strong>$10</strong> toward a future stay of
                2 or more nights.
              </li>
            </ul>
            <div class="pilot-actions">
              <button type="button" class="v2-button v2-button-blue pilot-accept" id="pilot-accept">
                I've read this — start booking
              </button>
            </div>
            <!-- The real booking widget, embedded in pilot mode. Revealed only after
                 the disclaimer is accepted (progressive disclosure keeps the terms front
                 and centre). Same-origin to the guest is crr.stratapms.com; the site CSP
                 allows framing that trusted subdomain (netlify.toml frame-src). -->
            <div class="pilot-embed-wrap" id="pilot-embed" hidden>
              <iframe
                class="pilot-embed"
                id="pilot-embed-frame"
                data-src={PILOT_EMBED_URL}
                title="Crooked River Ranch — new reservation system (pilot)"
                loading="lazy"
                referrerpolicy="no-referrer"
                sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
              ></iframe>
              <p class="pilot-go-note" id="pilot-go-note">
                On a small screen this is easier full-size —
                <a href={`${PILOT_URL}?pilot=1`} target="_blank" rel="noopener">open the pilot in a new tab &rarr;</a>.
                When you're done, call us at <a href="tel:+15419231441">541-923-1441</a> or mention your
                feedback when we follow up to confirm — that's all it takes to earn your $10 credit.
              </p>
            </div>
          </div>

          <p class="pilot-footnote v2-reveal">
            Questions first? Call the office at
            <a href="tel:+15419231441">541-923-1441</a> — we're happy to walk you
            through it. And thank you: pilots like this are how we make staying on the
            canyon rim even easier.
          </p>
        </div>
      </div>
    </section>
  </main>

  <style>
    /* light, V3-native touches only — everything structural comes from the
       crr-section / v2-shell / crr-live-panel system */
    .pilot-terms {
      list-style: none;
      margin: 1.1rem 0 1.6rem;
      padding: 0;
      display: grid;
      gap: 0.9rem;
    }
    .pilot-terms li {
      position: relative;
      padding-left: 1.6rem;
      line-height: 1.65;
    }
    .pilot-terms li::before {
      content: '\2713';
      position: absolute;
      left: 0;
      top: 0;
      font-weight: 700;
    }
    .pilot-actions { text-align: center; margin-top: 0.5rem; }
    .pilot-accept { cursor: pointer; font-family: inherit; }
    /* The embedded widget stays hidden until the disclaimer is accepted. */
    .pilot-gate.accepted .pilot-accept { display: none; }
    .pilot-embed-wrap { margin-top: 1.5rem; }
    .pilot-embed {
      width: 100%;
      height: min(85vh, 900px);
      min-height: 620px;
      border: 1px solid var(--v2-line, rgba(0,0,0,0.12));
      border-radius: 14px;
      background: #fff;
      display: block;
    }
    .pilot-go-note { margin-top: 1rem; font-size: 0.9rem; line-height: 1.6; text-align: center; }
    .pilot-footnote { margin-top: 2rem; line-height: 1.7; }
    @media (max-width: 640px) {
      .pilot-actions .v2-button { display: flex; width: 100%; justify-content: center; }
      .pilot-embed { height: min(90vh, 780px); min-height: 560px; }
    }
  </style>

  <script is:inline>
    // THE LIVE GATE: closed is the server-rendered default; only an explicit
    // ok && open from Rimrock (via the same-origin proxy) reveals the pilot.
    // Any failure leaves the closed notice standing — fail closed, never crash.
    (function () {
      var DAY_LABELS = {
        'mon-sat': 'Monday–Saturday',
        'mon-fri': 'Monday–Friday',
        'mon-sun': 'every day',
      };
      function fmtTime(t) {
        var m = /^(\d{1,2}):(\d{2})$/.exec(t || '');
        if (!m) return t || '';
        var h = parseInt(m[1], 10);
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h % 12 === 0 ? 12 : h % 12;
        return h12 + ':' + m[2] + ' ' + ampm;
      }
      fetch('/api/pilot-status', { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (s) {
          // defense-in-depth: require the proxy's own ok flag AND the gate flag
          if (s && s.ok === true && s.open === true) {
            var closed = document.getElementById('pilot-closed');
            var open = document.getElementById('pilot-open');
            if (closed) closed.hidden = true;
            if (open) open.hidden = false;
            return;
          }
          // stay closed; refine the schedule line when Rimrock told us one
          var sched = s && s.schedule;
          var el = document.getElementById('pilot-schedule');
          if (el && sched && sched.start && sched.end) {
            var days = DAY_LABELS[sched.days] || sched.days || '';
            el.textContent =
              days + ', ' + fmtTime(sched.start) + '–' + fmtTime(sched.end) + ' Pacific';
          }
        })
        .catch(function () { /* closed notice stands — fail closed */ });

      // Click-through disclaimer gate: reveal the embedded booking widget only after
      // acceptance (the iframe's src is server-rendered, so nothing loads the widget
      // — or fires any pilot request — until the guest has read + accepted the terms).
      var gate = document.getElementById('pilot-gate');
      var accept = document.getElementById('pilot-accept');
      if (gate && accept) {
        accept.addEventListener('click', function () {
          gate.classList.add('accepted');
          var embed = document.getElementById('pilot-embed');
          if (embed) {
            embed.hidden = false;
            var frame = document.getElementById('pilot-embed-frame');
            // load the widget ONLY now (src held in data-src), so no pilot request
            // fires — and no widget loads — before the guest has accepted the terms
            if (frame && !frame.getAttribute('src')) {
              var ds = frame.getAttribute('data-src');
              if (ds) frame.setAttribute('src', ds);
            }
            embed.scrollIntoView({ behavior: 'smooth', block: 'start' });
            if (frame) frame.focus();
          }
        });
      }
    })();
  </script>

  <!-- No JS ⇒ the gate cannot be checked ⇒ the closed notice stands (fail closed). -->
</Base>
