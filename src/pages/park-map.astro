---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import { getParkSites } from '@lib/area-guide';
import { ParkSiteMap } from '@components/react/ParkSiteMap.tsx';
import ParkMapPolygons from '@components/ParkMapPolygons.astro';
import { serverClient } from '@lib/supabase';

const sites = await getParkSites();
let activeParkMap: { id: string; slug: string; title: string; image_url: string; natural_width: number; natural_height: number } | null = null;
try {
  const { data } = await serverClient()
    .from('park_maps')
    .select('id, slug, title, image_url, natural_width, natural_height')
    .eq('is_active', true)
    .order('priority', { ascending: false })
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (data) activeParkMap = data as NonNullable<typeof activeParkMap>;
} catch {}

const polygonSites = sites.filter((site) => Array.isArray(site.map_polygon) && site.map_polygon.length > 0 && site.is_published !== false);
const usePolygonMap = Boolean(activeParkMap) && polygonSites.length > 0;
let mapImageUrl: string | null = null;
if (!usePolygonMap) {
  try {
    const { data } = await serverClient().from('pages').select('meta_description').eq('slug', '__park_map_config').maybeSingle();
    if (data?.meta_description?.startsWith('map_image_url=')) mapImageUrl = data.meta_description.slice('map_image_url='.length).trim() || null;
  } catch {}
}

const clientSites = sites.map((site) => ({
  id: site.id, site_number: site.site_number, loop: site.loop, length_feet: site.length_feet,
  width_feet: site.width_feet, pull_through: site.pull_through, amp_service: site.amp_service,
  site_type: site.site_type, nightly_rate: site.nightly_rate, hero_image_url: site.hero_image_url,
  description: site.description, features: site.features, map_position_x: site.map_position_x,
  map_position_y: site.map_position_y, firefly_deep_link: site.firefly_deep_link, is_available: site.is_available,
}));
const title = 'Interactive RV Park Map | Crooked River Ranch';
const description = 'Explore the Crooked River Ranch RV Park layout, open individual site details and photos, and compare locations near park amenities.';
const canonical = 'https://www.crookedriverranchrv.com/park-map';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/rv_park_map.jpg" heroImagePreload="/images/aerial_aloop.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Interactive park map"
      headline="Choose the site"
      accent="in context."
      body="See loops, site positions, and individual details together. Open a site for its fit, photos, status, and reservation path."
      image="/images/aerial_aloop.webp"
      imageMobile="/images/aerial_aloop-mobile.webp"
      imageJpg="/images/aerial_aloop.jpg"
      alt="Aerial view of RV sites among juniper trees"
      caption="Sites, loops, and park features"
      primaryHref="#interactive-map"
      primaryLabel="Open the map"
      secondaryHref="/availability"
      secondaryLabel="Search my dates"
    />
    <section class="crr-section crr-section-soft" id="interactive-map">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div><p class="v2-eyebrow">The full layout</p><h2>Open a site.<br />Understand the fit.</h2></div>
          <p>Use the map for location and site details. Use live availability when dates are the deciding factor.</p>
        </div>
        <div class="crr-map-panel v2-reveal">
          {!sites.length ? (
            <div class="crr-empty-state"><h3>The map is temporarily unavailable.</h3><p>Call <a href="tel:+15419231441">541-923-1441</a> for help choosing a site.</p></div>
          ) : usePolygonMap && activeParkMap ? (
            <ParkMapPolygons parkMap={activeParkMap} sites={polygonSites as any} />
          ) : (
            <ParkSiteMap client:load sites={clientSites} mapImageUrl={mapImageUrl} />
          )}
        </div>
      </div>
    </section>
    <FinalCta headline="Now add dates to the map." body="Filter open sites by the exact rig length, slides, and hookup preference." image="/images/aerial_canyon_rim.webp" primaryHref="/availability" primaryLabel="Check live availability" secondaryHref="/sites" secondaryLabel="Compare site types" />
  </main>
</Base>
