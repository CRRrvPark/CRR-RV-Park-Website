---
export const prerender = true;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';

const title = 'Park Rules & Policies | Crooked River Ranch RV Park';
const description = 'Review arrival times, quiet hours, propane-fire rules, pets, cancellations, vehicles, the dump station, and other Crooked River Ranch RV Park policies.';
const canonical = 'https://www.crookedriverranchrv.com/park-policies';
const schemas = [{
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What are check-in and check-out times?', acceptedAnswer: { '@type': 'Answer', text: 'Check-in is 2:00 PM. Check-out is 12:00 PM noon.' } },
    { '@type': 'Question', name: 'What are quiet hours?', acceptedAnswer: { '@type': 'Answer', text: 'Quiet hours are 10:00 PM to 7:00 AM. Generators are not allowed.' } },
    { '@type': 'Question', name: 'Are pets welcome?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Pets are welcome. They must be under physical control or on a leash no longer than six feet outside the designated off-leash area, and may not be left outside unattended.' } },
    { '@type': 'Question', name: 'Are campfires allowed?', acceptedAnswer: { '@type': 'Answer', text: 'Wood and charcoal fires are not allowed. Propane fire pits are permitted when flames do not exceed four inches. Barbecues must be propane or electric.' } },
  ],
}];
---
<Base title={title} description={description} canonical={canonical} schemas={schemas} ogImage="https://www.crookedriverranchrv.com/images/firepit_evening.jpg" heroImagePreload="/images/firepit_evening.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Park policies"
      headline="Park rules for"
      accent="a smoother stay."
      body="Arrival times, quiet hours, fires, pets, cancellations, and site use — the details that keep the park workable for everyone."
      image="/images/firepit_evening.webp"
      imageMobile="/images/firepit_evening-mobile.webp"
      imageJpg="/images/firepit_evening.jpg"
      alt="Family gathered around a propane fire at camp"
      caption="Propane fire pits are permitted within the posted flame limit"
      primaryHref="#policies"
      primaryLabel="Review the policies"
      secondaryHref="tel:+15419231441"
      secondaryLabel="Call with a question"
    />

    <section class="crr-section crr-section-soft" id="policies">
      <div class="v2-shell">
        <nav class="crr-policy-nav" aria-label="Policy shortcuts">
          <a href="#arrival">Arrival</a><a href="#fire">Fire safety</a><a href="#pets">Pets</a><a href="#quiet">Quiet hours</a><a href="#reservations">Reservations</a><a href="#vehicles">Vehicles</a><a href="#safety">Safety</a>
        </nav>
        <div class="crr-policy-list">
          <details id="arrival" open><summary>Arrival, departure, and registered guests</summary><div class="crr-policy-body"><p><strong>Check-in is 2:00 PM. Check-out is 12:00 noon.</strong> Follow posted signs, notices, and staff instructions. The registered guest is financially responsible for the people, pets, and damage associated with the site.</p><p>Rented RVs require advance notice to the park office. An additional night may be charged if a rental unit is not removed by noon checkout.</p></div></details>
          <details id="fire"><summary>Fire safety and outdoor cooking</summary><div class="crr-policy-body"><p><strong>No wood or charcoal fires are allowed.</strong> Barbecues must be propane or electric. Propane fire pits are permitted when the flame does not exceed four inches. Fire restrictions are enforced year-round because of high fire danger.</p></div></details>
          <details id="pets"><summary>Pets and the off-leash area</summary><div class="crr-policy-body"><p>Pets are welcome. Outside the designated off-leash dog area, a handler must keep each animal under physical control—confined or on a leash no longer than six feet. Animals may not be left outside the RV unattended.</p><p>Prevent excessive barking, harassment, intimidation, injury, or interference with people, wildlife, and other animals. Aggressive animals are not allowed. Clean up after pets immediately.</p></div></details>
          <details id="quiet"><summary>Quiet hours and generators</summary><div class="crr-policy-body"><p><strong>Quiet hours are 10:00 PM to 7:00 AM.</strong> Keep music, voices, and other noise from disturbing neighboring sites. Generators are not allowed at any time.</p></div></details>
          <details id="reservations"><summary>Deposits, changes, cancellations, and early departures</summary><div class="crr-policy-body"><p>Deposits are required and are non-refundable. When a guest cannot make a scheduled stay, the park will make reasonable efforts to reschedule it within the same calendar year.</p><ul><li>With more than 72 hours’ cancellation notice, the deposit is retained.</li><li>With less than 72 hours’ notice, full payment of the reservation is required.</li><li>Holiday-weekend cancellations and shortening a reservation require 10 days’ notice.</li><li>No refunds are issued for early departure.</li></ul><p>Your reservation confirmation controls if it states a different term for the specific booking. Call the office before changing or cancelling a stay.</p></div></details>
          <details id="vehicles"><summary>Parking, vehicles, and site use</summary><div class="crr-policy-body"><p>RV-park parking is for registered guests. Do not abandon a vehicle or leave one unattended for 72 hours or more without permission. Vehicles may be towed at the owner’s expense when the stated conditions for towing are met.</p><p>Do not wash RVs in the park. Dispose of RV sewage and gray water only at the designated dump station. The dump station is available 24/7 for $15 through the on-site card reader.</p></div></details>
          <details id="safety"><summary>Safety, golf-course adjacency, and management authority</summary><div class="crr-policy-body"><p>Guests use the facilities at their own risk. The park is adjacent to a golf course, and golf balls may enter the RV-park area. Stay alert and keep children and pets close near the canyon rim and other hazards.</p><p>Management interprets and enforces park rules and may require a guest to leave when conduct violates a rule, threatens safety, or substantially disrupts other guests. Rules may be amended to protect people and park resources.</p></div></details>
        </div>
      </div>
    </section>
    <FinalCta headline="Unsure about a rule?" body="Call 541-923-1441 before you arrive, or book online when you’re clear." image="/images/canyon_day.webp" primaryHref={FIREFLY_RESERVATION_URL} primaryLabel="Book your site" secondaryHref="tel:+15419231441" secondaryLabel="Call 541-923-1441" />
  </main>
</Base>
