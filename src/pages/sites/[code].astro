---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import { getParkSiteByCode, type ParkSiteStatus } from '@lib/area-guide';
import { FIREFLY_RESERVATION_URL } from '@lib/booking';

const code = Astro.params.code;
if (!code) return new Response('Not Found', { status: 404 });
const site = await getParkSiteByCode(code);
if (!site) return new Response('Not Found', { status: 404 });

const labels: Record<ParkSiteStatus, string> = {
  available: 'Available for booking',
  camp_host: 'Camp host site',
  staff_only: 'Call the office',
  maintenance: 'Under maintenance',
  reserved: 'Reserved',
  seasonal_closed: 'Seasonally closed',
};
const photos = [site.hero_image_url, ...(site.gallery_image_urls ?? [])].filter((url, index, list): url is string => Boolean(url) && list.indexOf(url) === index);
const isBookable = site.status === 'available';
const bookUrl = site.firefly_deep_link || FIREFLY_RESERVATION_URL;
const title = `Site ${site.site_number} · Loop ${site.loop} | Crooked River Ranch`;
const description = site.description
  ? site.description.replace(/<[^>]+>/g, '').slice(0, 155)
  : `Review Site ${site.site_number} in Loop ${site.loop}, including layout, hookups, listed fit, photos, status, and reservation path.`;
const canonical = `https://www.crookedriverranchrv.com/sites/${encodeURIComponent(site.site_number)}`;
---
<Base title={title} description={description} canonical={canonical} ogImage={site.hero_image_url ?? 'https://www.crookedriverranchrv.com/images/aerial_aloop.jpg'}>
  <main id="main-content">
    <PageHero
      eyebrow={`Loop ${site.loop} · ${labels[site.status]}`}
      headline={`Site ${site.site_number}`}
      body={site.description ? site.description.replace(/<[^>]+>/g, '') : `${site.pull_through ? 'Pull-through' : 'Back-in'} site${site.length_feet ? ` with a listed fit up to ${site.length_feet} feet` : ''}.`}
      image={site.hero_image_url ?? '/images/aerial_aloop.webp'}
      imageJpg={site.hero_image_url ?? '/images/aerial_aloop.jpg'}
      alt={site.hero_image_url ? `Site ${site.site_number} at Crooked River Ranch RV Park` : 'Aerial view of RV sites among junipers'}
      caption={site.hero_image_url ? `Actual photo · Site ${site.site_number}` : 'Park overview · Individual photo coming soon'}
      primaryHref={isBookable ? bookUrl : 'tel:+15419231441'}
      primaryLabel={isBookable ? 'Book this site' : 'Call about this site'}
      secondaryHref="/park-map"
      secondaryLabel="Back to the park map"
    />

    <section class="crr-section crr-section-soft">
      <div class="v2-shell">
        {site.status !== 'available' && <div class="crr-alert v2-reveal"><strong>{labels[site.status]}</strong><p>{site.status_note ?? 'This site is not currently available for online self-booking. Call the office for help.'}</p></div>}
        <div class="crr-site-detail-grid">
          <div>
            <p class="v2-eyebrow">About this site</p>
            <div class="crr-prose" set:html={site.description || `<p>${site.pull_through ? 'Pull-through' : 'Back-in'} site in Loop ${site.loop}${site.length_feet ? ` with a listed fit up to ${site.length_feet} feet` : ''}${site.amp_service ? ` and ${site.amp_service}-amp electric service` : ''}.</p>`}></div>
            {site.features?.length > 0 && <div class="crr-list-card-meta" style="margin-top:24px;">{site.features.map((feature) => <span>{feature}</span>)}</div>}
          </div>
          <aside class="crr-site-sidebar">
            <p class="v2-eyebrow">Site details</p>
            <dl>
              <div><dt>Loop</dt><dd>{site.loop}</dd></div>
              {site.site_type && <div><dt>Site type</dt><dd>{site.site_type}</dd></div>}
              {site.length_feet && <div><dt>Listed length</dt><dd>{site.length_feet} ft</dd></div>}
              {site.width_feet && <div><dt>Listed width</dt><dd>{site.width_feet} ft</dd></div>}
              <div><dt>Layout</dt><dd>{site.pull_through ? 'Pull-through' : 'Back-in'}</dd></div>
              {site.amp_service && <div><dt>Electric</dt><dd>{site.amp_service} amp</dd></div>}
              {site.nightly_rate && <div><dt>Nightly</dt><dd>${site.nightly_rate}</dd></div>}
              {site.weekly_rate && <div><dt>Weekly</dt><dd>${site.weekly_rate}</dd></div>}
              {site.monthly_rate && <div><dt>Monthly</dt><dd>${site.monthly_rate}</dd></div>}
            </dl>
            {isBookable ? <a class="v2-button v2-button-blue" href={bookUrl} target="_blank" rel="noreferrer">Book this site <span aria-hidden="true">↗</span></a> : <a class="v2-button v2-button-blue" href="tel:+15419231441">Call 541-923-1441 <span aria-hidden="true">→</span></a>}
          </aside>
        </div>
      </div>
    </section>

    <section class="crr-section">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal"><div><p class="v2-eyebrow">Site photos</p><h2>Photos of this site</h2></div><p>Photos show this individual site when labeled as such. Use listed dimensions and call the office when slide clearance is uncertain.</p></div>
        {photos.length ? (
          <div class="crr-site-photo-grid">
            {photos.map((photo, index) => <a href={photo} data-lightbox="true" class="v2-reveal"><img src={photo} alt={`Site ${site.site_number} photo ${index + 1}`} loading={index ? 'lazy' : 'eager'} /></a>)}
          </div>
        ) : (
          <div class="crr-empty-state v2-reveal"><h3>Individual photos are coming.</h3><p>Use the <a href="/park-map">park map</a> for location, then call the office if a site-specific view would help the decision.</p></div>
        )}
      </div>
    </section>
    <FinalCta headline={`Questions about Site ${site.site_number}?`} body="Reserve online when it’s bookable, or call the office for help with slides and exact fit." image="/images/canyon_sunset.webp" primaryHref={isBookable ? bookUrl : 'tel:+15419231441'} primaryLabel={isBookable ? 'Book this site' : 'Call about this site'} secondaryHref="/park-map" secondaryLabel="Compare on the park map" />
  </main>
</Base>
