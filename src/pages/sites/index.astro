---
export const prerender = true;

import Base from '@layouts/Base.astro';
import GuestReviews from '@components/site/GuestReviews.astro';
import FinalCta from '@components/site/FinalCta.astro';
import PageHero from '@components/site/PageHero.astro';

const title = 'RV Sites & Site Types | Crooked River Ranch RV Park';
const description = 'Compare full-hookup, water-and-electric, tent, and dry-camp sites at Crooked River Ranch RV Park near Smith Rock. See length limits, photos, and the park map, then book online.';
const canonical = 'https://www.crookedriverranchrv.com/sites';
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage="https://www.crookedriverranchrv.com/images/aerial_wide.jpg"
  heroImagePreload="/images/aerial_wide.webp"
>
  <main id="main-content">
    <PageHero
      eyebrow="Sites"
      headline="Find a site that"
      accent="fits your rig."
      body="Hookups, length, setup style, and where you’ll sit in the park — then reserve online when you’re ready."
      image="/images/aerial_wide.webp"
      imageMobile="/images/aerial_wide-mobile.webp"
      imageJpg="/images/aerial_wide.jpg"
      alt="Wide aerial view of Crooked River Ranch RV Park, canyon, golf course, and Cascade Mountains"
      caption="RV sites beside the canyon and golf course"
      primaryHref="#site-types"
      primaryLabel="Compare site types"
      secondaryHref="/park-map"
      secondaryLabel="Open the park map"
    />

    <section class="crr-section crr-section-soft">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Choose with confidence</p>
            <h2>More than “is it open?”</h2>
          </div>
          <p>You’ll want to know the hookups, how long a rig it takes, and how close you are to the pool, dog run, or canyon rim. Photos and the park map help; guest reviews add what the specs don’t.</p>
        </div>

        <div class="crr-confidence-grid">
          <a class="crr-confidence-card crr-confidence-card-photo v2-reveal" href="/park-map">
            <img src="/images/aerial_aloop.webp" alt="Aerial view of RV sites among junipers" loading="lazy" />
            <div>
              <span>See the actual park</span>
              <h3>Photos and location together.</h3>
              <p>Use the interactive map to understand the loop, nearby amenities, and available site photos.</p>
              <strong>Explore the park map →</strong>
            </div>
          </a>
          <a class="crr-confidence-card v2-reveal" href="#comparison">
            <span aria-hidden="true">↔</span>
            <h3>Compare the useful specs.</h3>
            <p>Hookups, listed fit, setup type, bathhouse access, and dump-station details stay in one place.</p>
            <strong>View the comparison →</strong>
          </a>
          <a class="crr-confidence-card v2-reveal" href="#guest-reviews">
            <span aria-hidden="true">★</span>
            <h3>Hear from people who stayed.</h3>
            <p>Guest reviews add what a dimensions table cannot: quiet, space, ease, and how the park feels.</p>
            <strong>Read guest reviews →</strong>
          </a>
        </div>

        <div class="crr-site-gallery v2-reveal" aria-label="Views of Crooked River Ranch RV Park">
          <figure>
            <img src="/images/aerial_canyon_rim.webp" alt="RV park beside the Crooked River canyon" loading="lazy" />
            <figcaption>Canyon rim</figcaption>
          </figure>
          <figure>
            <img src="/images/gazebo_fall.webp" alt="Gazebo and autumn trees in the park" loading="lazy" />
            <figcaption>Shared spaces</figcaption>
          </figure>
          <figure>
            <img src="/images/pool.webp" alt="Heated seasonal swimming pool" loading="lazy" />
            <figcaption>Heated pool</figcaption>
          </figure>
          <figure>
            <img src="/images/firepit_evening.webp" alt="Guests gathered around a propane fire at camp" loading="lazy" />
            <figcaption>Evening at camp</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="v2-section v2-matcher-section" id="site-types">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal">
          <div>
            <p class="v2-eyebrow">Four ways to stay</p>
            <h2>Four site types</h2>
          </div>
          <p>Start here, then open the map or book online.</p>
        </div>

        <div class="v2-site-product-grid">
          <article class="v2-site-product v2-reveal" id="full-hookup">
            <div class="v2-site-product-top"><span>01</span><small>Full hookup</small></div>
            <h3>Full Hookup RV Site</h3>
            <p>Water, 30/50 amp electric, and sewer with back-in and pull-through choices.</p>
            <dl>
              <div><dt>Length</dt><dd>Guest-bookable pull-throughs up to 65 ft</dd></div>
              <div><dt>Setup</dt><dd>Back-in + pull-through</dd></div>
              <div><dt>Slides</dt><dd>Confirm against the live site details</dd></div>
            </dl>
            <a href="/availability?type=full-hookup#live-availability">Request full-hookup on the live map beta →</a>
          </article>

          <article class="v2-site-product v2-reveal" id="water-electric">
            <div class="v2-site-product-top"><span>02</span><small>Water + electric</small></div>
            <h3>Water &amp; Electric Site</h3>
            <p>Water and 30/50 amp electric without a sewer connection at the site.</p>
            <dl>
              <div><dt>Length</dt><dd>Listed options up to 50 ft</dd></div>
              <div><dt>Setup</dt><dd>Back-in + pull-through</dd></div>
              <div><dt>Park service</dt><dd>$15 dump station · card reader · 24/7</dd></div>
            </dl>
            <a href="/availability?type=water_electric#live-availability">Request water + electric on the live map beta →</a>
          </article>

          <article class="v2-site-product v2-reveal" id="tent-dry">
            <div class="v2-site-product-top"><span>03</span><small>Tent stay</small></div>
            <h3>Tent Site</h3>
            <p>Traditional tent sites and designated rooftop-tent options under the trees.</p>
            <dl>
              <div><dt>Hookups</dt><dd>None</dd></div>
              <div><dt>Setup</dt><dd>Ground + select rooftop tents</dd></div>
              <div><dt>Park service</dt><dd>Free showers + coin-op laundry</dd></div>
            </dl>
            <a href="/availability?type=tent#live-availability">Request a tent site on the live map beta →</a>
          </article>

          <article class="v2-site-product v2-reveal" id="dry-camp">
            <div class="v2-site-product-top"><span>04</span><small>Dry camp</small></div>
            <h3>Small-Rig Dry Camp</h3>
            <p>No-hookup sites for qualifying camper vans and truck campers.</p>
            <dl>
              <div><dt>Length</dt><dd>Single vehicles up to 25 ft</dd></div>
              <div><dt>Setup</dt><dd>Van + truck camper</dd></div>
              <div><dt>Park service</dt><dd>$15 dump station · card reader · 24/7</dd></div>
            </dl>
            <a href="/availability?type=dry#live-availability">Request dry camp on the live map beta →</a>
          </article>
        </div>
      </div>
    </section>

    <section class="crr-section crr-section-dark" id="comparison">
      <div class="v2-shell">
        <div class="v2-compare-heading v2-reveal">
          <p class="v2-eyebrow">At a glance</p>
          <h2>Compare the differences</h2>
        </div>
        <div class="crr-table-wrap v2-reveal">
          <table class="crr-table">
            <thead>
              <tr>
                <th scope="col">Site type</th>
                <th scope="col">Water</th>
                <th scope="col">Electric</th>
                <th scope="col">Sewer</th>
                <th scope="col">Largest listed fit</th>
                <th scope="col">Next step</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Full hookup</th><td>Yes</td><td>30/50 amp</td><td>At site</td><td>65 ft pull-through</td><td><a href="/availability?type=full-hookup#live-availability">Live map beta →</a></td></tr>
              <tr><th scope="row">Water + electric</th><td>Yes</td><td>30/50 amp</td><td>Dump station</td><td>50 ft</td><td><a href="/availability?type=water_electric#live-availability">Live map beta →</a></td></tr>
              <tr><th scope="row">Tent</th><td>No</td><td>No</td><td>No</td><td>Ground + select rooftop</td><td><a href="/availability?type=tent#live-availability">Live map beta →</a></td></tr>
              <tr><th scope="row">Dry camp</th><td>No</td><td>No</td><td>No</td><td>25 ft single vehicle</td><td><a href="/availability?type=dry#live-availability">Live map beta →</a></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="crr-section">
      <div class="v2-shell crr-two-column">
        <div class="crr-copy v2-reveal">
          <p class="v2-eyebrow">Location matters too</p>
          <h2>See the whole park while you choose.</h2>
          <p>Pool, bathhouse, dog run, playground, golf course, and canyon rim — all in view on the interactive map. Open individual sites for photos and dimensions where available.</p>
          <a class="v2-button v2-button-blue" href="/park-map">Open the interactive park map <span aria-hidden="true">→</span></a>
        </div>
        <figure class="crr-media v2-reveal">
          <img src="/images/rv_park_map.webp" alt="Crooked River Ranch RV Park site map" loading="lazy" />
          <figcaption>Interactive site map available</figcaption>
        </figure>
      </div>
    </section>

    <div id="guest-reviews">
      <GuestReviews />
    </div>

    <section class="v2-alt-stays">
      <img src="/images/firepit_evening.webp" alt="Family gathered outdoors around a propane fire in the evening" loading="lazy" />
      <div class="v2-alt-overlay"></div>
      <div class="v2-shell v2-alt-inner v2-reveal">
        <p class="v2-eyebrow v2-eyebrow-light">Planning something specific?</p>
        <h2>Group, extended,<br />and golf stays.</h2>
        <div>
          <a href="/group-sites">Group stays <span>→</span></a>
          <a href="/extended-stays">Extended stays <span>→</span></a>
          <a href="/golf-stays">Golf stays <span>→</span></a>
        </div>
      </div>
    </section>

    <FinalCta
      headline="Know the fit. Then book."
      body="Bring your rig length and slide setup, or call 541-923-1441 if you want a second opinion."
    />
  </main>
</Base>
