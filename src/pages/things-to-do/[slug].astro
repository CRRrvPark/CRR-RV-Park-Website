---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import GoogleMap, { type Pin } from '@components/GoogleMap.astro';
import { getThingBySlug, CATEGORY_LABELS } from '@lib/area-guide';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/things-to-do', 302);
const thing = await getThingBySlug(slug);
if (!thing) return Astro.redirect('/things-to-do?not-found=1', 302);
const pins: Pin[] = thing.lat !== null && thing.lng !== null
  ? [{ lat: thing.lat, lng: thing.lng, title: thing.title, description: thing.summary ?? undefined, iconEmoji: thing.icon || '📍' }]
  : [];
const title = `${thing.title} | Things to Do near Crooked River Ranch`;
const description = thing.summary ?? `${thing.title} in Central Oregon near Crooked River Ranch RV Park.`;
const canonical = `https://www.crookedriverranchrv.com/things-to-do/${thing.slug}`;
---
<Base title={title} description={description} canonical={canonical} ogImage={thing.hero_image_url ?? undefined}>
  <main id="main-content">
    <PageHero
      eyebrow={`${CATEGORY_LABELS[thing.category]}${thing.distance_from_park ? ` · ${thing.distance_from_park}` : ''}`}
      headline={thing.title}
      body={thing.summary ?? 'Add this idea to the day, then use the location and source details to finish the plan.'}
      image={thing.hero_image_url ?? '/images/central_oregon.webp'}
      imageJpg={thing.hero_image_url ?? '/images/central_oregon.jpg'}
      alt={thing.title}
      caption={thing.location_name ?? 'Central Oregon'}
      primaryHref="#details"
      primaryLabel="See the details"
      secondaryHref="/things-to-do"
      secondaryLabel="Browse all ideas"
    />

    <section class="crr-section" id="details">
      <div class="v2-shell crr-two-column">
        <div class="v2-reveal">
          <p class="v2-eyebrow">{CATEGORY_LABELS[thing.category]}</p>
          <div class="crr-prose" set:html={thing.details_html || thing.description || '<p>Use the location details and outside reference to finish planning this stop.</p>'}></div>
          {thing.external_link && <a class="v2-button v2-button-blue" href={thing.external_link} target="_blank" rel="noreferrer">Open current details <span aria-hidden="true">↗</span></a>}
        </div>
        <div class="v2-reveal">
          {pins.length ? (
            <div class="crr-map-panel">
              <p class="v2-eyebrow">Location</p>
              {thing.location_name && <h3 style="margin-bottom:18px;">{thing.location_name}</h3>}
              <GoogleMap id={`thing-map-${thing.slug}`} pins={pins} centerLat={thing.lat!} centerLng={thing.lng!} zoom={13} mapTypeId="roadmap" height="430px" fitBounds={false} />
            </div>
          ) : (
            <figure class="crr-media"><img src="/images/canyon_day.webp" alt="Crooked River canyon near the RV park" loading="lazy" /><figcaption>Return to the canyon when the outing is done</figcaption></figure>
          )}
        </div>
      </div>
    </section>
    <FinalCta headline="Make this part of the trip—not another planning chore." body="Choose the RV site with live availability and keep the rest of the day flexible." image="/images/canyon_sunset.webp" secondaryHref="/things-to-do" secondaryLabel="Browse another idea" />
  </main>
</Base>
