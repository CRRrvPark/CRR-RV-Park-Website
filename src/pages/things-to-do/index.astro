---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import { getThingsToDo, CATEGORY_LABELS, type ThingCategory } from '@lib/area-guide';

const things = await getThingsToDo();
const categories: { key: 'all' | ThingCategory; label: string }[] = [
  { key: 'all', label: 'All ideas' },
  { key: 'families', label: 'Families' },
  { key: 'active', label: 'Active days' },
  { key: 'rvers', label: 'At camp' },
  { key: 'dogs', label: 'With pets' },
  { key: 'day_trippers', label: 'Day trips' },
  { key: 'winter', label: 'Winter' },
  { key: 'food_community', label: 'Food + community' },
];
const title = 'Things to Do near Crooked River Ranch RV Park';
const description = 'Filter Central Oregon trip ideas by the kind of day you want, then open practical location, distance, and planning details.';
const canonical = 'https://www.crookedriverranchrv.com/things-to-do';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/central_oregon.jpg" heroImagePreload="/images/central_oregon.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Things to do"
      headline="Start with the day"
      accent="you actually want."
      body="Choose active, easy, family, pet-friendly, winter, or food-and-community ideas. Open any card for the practical details."
      image="/images/central_oregon.webp"
      imageMobile="/images/central_oregon-mobile.webp"
      imageJpg="/images/central_oregon.jpg"
      alt="Central Oregon landscape near Crooked River Ranch"
      caption="Trip ideas organized around the guest"
      primaryHref="#ideas"
      primaryLabel="Browse ideas"
      secondaryHref="/area-guide#area-map"
      secondaryLabel="Open the area map"
    />

    <div class="crr-filter-bar">
      <div class="v2-shell crr-filter-row" role="group" aria-label="Filter activities">
        {categories.map((category) => <button type="button" data-filter={category.key} aria-pressed={category.key === 'all' ? 'true' : 'false'}>{category.label}</button>)}
      </div>
    </div>

    <section class="crr-section crr-section-soft" id="ideas">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal"><div><p class="v2-eyebrow">Build the day</p><h2>Pick an idea.<br />Keep the rest flexible.</h2></div><p>Distance and category stay visible. Each detail page carries the location and outside source when one is available.</p></div>
        {!things.length ? (
          <div class="crr-empty-state"><h3>The activity guide is refreshing.</h3><p>Use the <a href="/area-guide">park + area guide</a> in the meantime.</p></div>
        ) : (
          <div class="crr-card-grid" data-filter-grid>
            {things.map((thing) => (
              <a class="crr-list-card v2-reveal" href={`/things-to-do/${thing.slug}`} data-category={thing.category} data-personas={thing.personas.join(',')}>
                <div class="crr-list-card-visual">
                  {thing.hero_image_url ? <img src={thing.hero_image_url} alt={thing.title} loading="lazy" /> : <span class="crr-list-card-badge">{thing.icon ?? 'Explore'}</span>}
                  {thing.distance_from_park && <span class="crr-list-card-badge">{thing.distance_from_park}</span>}
                </div>
                <div class="crr-list-card-body">
                  <small>{CATEGORY_LABELS[thing.category]}</small>
                  <h3>{thing.title}</h3>
                  {thing.summary && <p>{thing.summary}</p>}
                  <div class="crr-list-card-meta">{thing.personas.slice(0, 3).map((persona) => <span>{CATEGORY_LABELS[persona]}</span>)}</div>
                </div>
              </a>
            ))}
            <div class="crr-empty-state" data-filter-empty hidden><h3>No ideas match that filter yet.</h3><p>Try another category or open the full area map.</p></div>
          </div>
        )}
      </div>
    </section>
    <FinalCta headline="The site stays ready while you explore." body="Use live availability for the home base, then decide how much of Central Oregon belongs in the trip." image="/images/firepit_evening.webp" />
  </main>
  <script is:inline>
    (() => {
      const buttons = document.querySelectorAll('.crr-filter-row [data-filter]');
      const cards = document.querySelectorAll('[data-filter-grid] .crr-list-card');
      const empty = document.querySelector('[data-filter-empty]');
      const apply = (filter) => {
        let visible = 0;
        cards.forEach((card) => {
          const categories = `${card.dataset.category || ''},${card.dataset.personas || ''}`.split(',');
          const match = filter === 'all' || categories.includes(filter);
          card.hidden = !match;
          if (match) visible += 1;
        });
        if (empty) empty.hidden = visible !== 0;
      };
      buttons.forEach((button) => button.addEventListener('click', () => {
        buttons.forEach((item) => item.setAttribute('aria-pressed', 'false'));
        button.setAttribute('aria-pressed', 'true');
        apply(button.dataset.filter || 'all');
      }));
    })();
  </script>
</Base>
