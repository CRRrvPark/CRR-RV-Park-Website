---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import GoogleMap, { type Pin } from '@components/GoogleMap.astro';
import { getTrailBySlug, DIFFICULTY_LABELS, formatDistance, formatElevation, formatHazard } from '@lib/area-guide';
import { getGooglePlaceIdFromPhotoUrl } from '@lib/place-photo';

const { slug } = Astro.params;
if (!slug) return new Response('Not Found', { status: 404 });
const trail = await getTrailBySlug(slug);
if (!trail) return new Response('Not Found', { status: 404 });
const pins: Pin[] = trail.trailhead_lat !== null && trail.trailhead_lng !== null
  ? [{ lat: trail.trailhead_lat, lng: trail.trailhead_lng, title: trail.name, description: trail.parking_info ?? undefined, iconEmoji: '🥾' }]
  : [];
const title = `${trail.name} Trail Guide | Crooked River Ranch RV Park`;
const description = trail.summary ?? `Plan a visit to ${trail.name} from Crooked River Ranch RV Park.`;
const canonical = `https://www.crookedriverranchrv.com/trails/${trail.slug}`;
// Trail heroes are Static Maps of the trailhead (no Place ID), so this is null
// today and PageHero renders the map. It future-proofs any trail hero later
// backfilled to a Google Place photo (then it uses the progressive loader).
const googlePlaceId = getGooglePlaceIdFromPhotoUrl(trail.hero_image_url);
---
<Base title={title} description={description} canonical={canonical} ogImage={trail.hero_image_url ?? undefined}>
  <main id="main-content">
    <PageHero
      eyebrow={`${trail.is_on_property ? 'At the ranch' : 'Nearby trail'}${trail.drive_time_from_park ? ` · ${trail.drive_time_from_park}` : ''}`}
      headline={trail.name}
      body={trail.summary ?? 'Review the known route details, cautions, and trailhead before departure.'}
      image={trail.hero_image_url ?? '/images/smith_rock.webp'}
      imageJpg={trail.hero_image_url ?? '/images/smith_rock.jpg'}
      alt={trail.name}
      caption="Confirm current access and conditions before departure"
      googlePlaceId={googlePlaceId ?? undefined}
      primaryHref="#trail-details"
      primaryLabel="Review trail details"
      secondaryHref="/trails"
      secondaryLabel="Back to all trails"
    />

    <section class="crr-section crr-section-soft" id="trail-details">
      <div class="v2-shell">
        <div class="crr-stat-grid v2-reveal">
          {formatDistance(trail) && <div class="crr-stat"><small>Distance</small><strong>{formatDistance(trail)}</strong></div>}
          {formatElevation(trail) && <div class="crr-stat"><small>Elevation gain</small><strong>{formatElevation(trail)}</strong></div>}
          {trail.difficulty && <div class="crr-stat"><small>Difficulty</small><strong>{DIFFICULTY_LABELS[trail.difficulty]}</strong></div>}
          {trail.season && <div class="crr-stat"><small>Season</small><strong>{trail.season}</strong></div>}
          <div class="crr-stat"><small>Good to know</small><strong>{[trail.pet_friendly && 'Pets', trail.kid_friendly && 'Kids'].filter(Boolean).join(' + ') || 'Review route'}</strong></div>
        </div>
        {trail.hazards?.length > 0 && <div class="crr-alert v2-reveal" style="margin-top:18px;"><strong>Before you go</strong><div>{trail.hazards.map((hazard) => <span>{formatHazard(hazard)}</span>)}</div></div>}
      </div>
    </section>

    {(trail.description || pins.length) && (
      <section class="crr-section">
        <div class="v2-shell crr-two-column">
          <div class="v2-reveal">
            <p class="v2-eyebrow">Route notes</p>
            <div class="crr-prose" set:html={trail.description ?? '<p>Use the trailhead map and confirm current conditions before leaving the park.</p>'}></div>
            {trail.external_link && <a class="v2-inline-link" href={trail.external_link} target="_blank" rel="noreferrer">Open the external trail reference <span aria-hidden="true">↗</span></a>}
          </div>
          <div class="v2-reveal">
            {pins.length ? (
              <div class="crr-map-panel">
                <p class="v2-eyebrow">Trailhead</p>
                {trail.parking_info && <p style="margin-bottom:18px;color:var(--crr-muted);">{trail.parking_info}</p>}
                <GoogleMap id={`trail-map-${trail.slug}`} pins={pins} centerLat={trail.trailhead_lat!} centerLng={trail.trailhead_lng!} zoom={14} mapTypeId="terrain" height="430px" fitBounds={false} />
              </div>
            ) : <figure class="crr-media"><img src="/images/canyon_day.webp" alt="Crooked River canyon in daylight" loading="lazy" /></figure>}
          </div>
        </div>
      </section>
    )}
    <FinalCta headline="Let the trail be the outing—not the logistics." body="Choose a compatible site with live availability and return to camp when the day is done." image="/images/aerial_canyon_rim.webp" secondaryHref="/trails" secondaryLabel="Browse another trail" />
  </main>
</Base>
