---
export const prerender = false;

import Base from '@layouts/Base.astro';
import PageHero from '@components/site/PageHero.astro';
import FinalCta from '@components/site/FinalCta.astro';
import GoogleMap, { type Pin } from '@components/GoogleMap.astro';
import { getTrails, DIFFICULTY_LABELS, formatDistance, formatElevation } from '@lib/area-guide';
import { getGooglePlaceIdFromPhotoUrl } from '@lib/place-photo';

const trails = await getTrails();
const onProperty = trails.filter((trail) => trail.is_on_property);
const nearby = trails.filter((trail) => !trail.is_on_property);
const pins: Pin[] = trails
  .filter((trail) => trail.trailhead_lat !== null && trail.trailhead_lng !== null)
  .map((trail) => ({ lat: trail.trailhead_lat!, lng: trail.trailhead_lng!, title: trail.name, description: trail.summary ?? undefined, href: `/trails/${trail.slug}`, iconEmoji: '🥾' }));
const title = 'Trails near Crooked River Ranch RV Park | Central Oregon';
const description = 'Compare nearby Central Oregon trails by distance, difficulty, elevation, hazards, pet suitability, and trailhead location.';
const canonical = 'https://www.crookedriverranchrv.com/trails';
---
<Base title={title} description={description} canonical={canonical} ogImage="https://www.crookedriverranchrv.com/images/smith_rock.jpg" heroImagePreload="/images/smith_rock.webp">
  <main id="main-content">
    <PageHero
      eyebrow="Trails"
      headline="Choose the walk"
      accent="before the trailhead."
      body="See difficulty, distance, elevation, cautions, and drive time before the group commits to the route."
      image="/images/smith_rock.webp"
      imageMobile="/images/smith_rock-mobile.webp"
      imageJpg="/images/smith_rock.jpg"
      alt="Smith Rock cliffs and trail beside the Crooked River"
      caption="Trail details designed for an easier decision"
      primaryHref="#trail-list"
      primaryLabel="Compare trails"
      secondaryHref="#trail-map"
      secondaryLabel="Open the trail map"
    />

    <section class="crr-section crr-section-soft" id="trail-map">
      <div class="v2-shell">
        <div class="v2-section-heading v2-reveal"><div><p class="v2-eyebrow">Location first</p><h2>See the drive<br />before the hike.</h2></div><p>Open a map pin for the matching trail guide, then confirm current access and conditions before departure.</p></div>
        <div class="crr-map-panel v2-reveal">
          {pins.length ? <GoogleMap id="trails-map" pins={pins} centerLat={44.3485} centerLng={-121.2055} zoom={11} mapTypeId="terrain" height="520px" /> : <div class="crr-empty-state"><h3>Trail locations are refreshing.</h3><p>The trail cards remain available below.</p></div>}
        </div>
      </div>
    </section>

    <section class="crr-section" id="trail-list">
      <div class="v2-shell">
        {!trails.length ? (
          <div class="crr-empty-state"><h3>The trail guide is refreshing.</h3><p>Try the <a href="/area-guide">area guide</a> or check back shortly.</p></div>
        ) : (
          [
            { label: 'At the ranch', heading: 'Walk from the park.', items: onProperty },
            { label: 'Around Central Oregon', heading: 'Drive to the trailhead.', items: nearby },
          ].map((group) => group.items.length ? (
            <section class="crr-list-section">
              <div class="v2-section-heading v2-reveal"><div><p class="v2-eyebrow">{group.label}</p><h2>{group.heading}</h2></div><p>Every card opens a practical guide with known cautions, parking information, and a mapped start when available.</p></div>
              <div class="crr-card-grid">
                {group.items.map((trail) => {
                  // Trail heroes are Google Static Maps of the trailhead
                  // (/api/static-map, same-origin) — they carry no Place ID, so
                  // this is null today and the card renders the map through the
                  // graceful loader below. It future-proofs any trail hero that
                  // is ever backfilled to a Google Place photo.
                  const googlePlaceId = getGooglePlaceIdFromPhotoUrl(trail.hero_image_url);
                  return (
                  <a class="crr-list-card v2-reveal" href={`/trails/${trail.slug}`}>
                    <div
                      class:list={['crr-list-card-visual', googlePlaceId && 'crr-google-place-photo']}
                      data-google-place-photo={googlePlaceId || undefined}
                      data-photo-width={googlePlaceId ? '1200' : undefined}
                    >
                      <span class="crr-photo-placeholder" aria-hidden="true">{trail.is_on_property ? 'On property' : 'Trail'}</span>
                      {googlePlaceId ? (
                        <>
                          <img data-google-photo-image alt={trail.name} loading="lazy" />
                          <small class="crr-google-photo-attribution" data-google-photo-attribution hidden></small>
                        </>
                      ) : trail.hero_image_url ? (
                        <img src={trail.hero_image_url} alt={trail.name} loading="lazy" data-card-image />
                      ) : null}
                      {trail.drive_time_from_park && <span class="crr-list-card-badge">{trail.drive_time_from_park}</span>}
                    </div>
                    <div class="crr-list-card-body">
                      <small>{trail.is_on_property ? 'On property' : 'Nearby trail'}</small>
                      <h3>{trail.name}</h3>
                      {trail.summary && <p>{trail.summary}</p>}
                      <div class="crr-list-card-meta">
                        {trail.difficulty && <span>{DIFFICULTY_LABELS[trail.difficulty]}</span>}
                        {formatDistance(trail) && <span>{formatDistance(trail)}</span>}
                        {formatElevation(trail) && <span>{formatElevation(trail)}</span>}
                        {trail.pet_friendly && <span>Pet friendly</span>}
                        {trail.kid_friendly && <span>Kid friendly</span>}
                      </div>
                    </div>
                  </a>
                  );
                })}
              </div>
            </section>
          ) : null)
        )}
      </div>
    </section>
    <FinalCta headline="Come back to a site that is already set." body="Find an open RV site, then choose as much trail—or as little—as the day calls for." image="/images/canyon_sunset.webp" />
  </main>
</Base>
